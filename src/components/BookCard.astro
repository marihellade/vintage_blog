---
import { starsHtml, starsLabel } from '../utils/stars';

type BookCardVariant = 'reading' | 'reviewed' | 'dnf' | 'wishlist';

interface Props {
  title: string;
  author: string;
  cover: string | null;
  coverGradient: string;
  slug: string;
  variant: BookCardVariant;
  rating?: number | null;
  ratingText?: string | null;
  ratingLabel?: string | null;
  mood?: string | null;
  tags?: string[];
  series?: string;
  seriesNumber?: number;
  finishedLabel?: string;
}

const {
  title,
  author,
  cover,
  coverGradient,
  slug,
  variant,
  rating = null,
  ratingText = null,
  ratingLabel = null,
  mood = null,
  tags = [],
  series,
  seriesNumber,
  finishedLabel,
} = Astro.props;

const TitleTag = variant === 'reviewed' ? 'h3' : 'h4';
const cardClasses = [
  'book-card',
  'card',
  variant === 'reviewed' && 'reviewed-card',
  variant === 'dnf' && 'dnf-card',
];
const placeholderClasses = [
  'book-cover-placeholder',
  variant === 'reviewed' && 'reviewed-book-cover-placeholder',
  variant === 'wishlist' && 'wishlist',
  variant === 'dnf' && 'dnf',
];
const shouldUseImage = variant !== 'wishlist' && Boolean(cover);
const displayedRatingText = typeof rating === 'number'
  ? ratingText ?? starsHtml(rating)
  : null;
const displayedRatingLabel = typeof rating === 'number'
  ? ratingLabel ?? starsLabel(rating)
  : null;
---

<a href={`/books/${slug}`} class:list={cardClasses}>
  {variant === 'reviewed' ? (
    <>
      <div class="reviewed-card-figure">
        {shouldUseImage ? (
          <img
            src={cover ?? undefined}
            alt={`Cover of ${title}`}
            class="book-cover reviewed-book-cover"
            loading="lazy"
          />
        ) : (
          <div class:list={placeholderClasses} style={`background: ${coverGradient}`}>
            <span>{title.charAt(0)}</span>
          </div>
        )}
      </div>
      <div class="book-info reviewed-card-copy">
        <TitleTag class="reviewed-card-title">{title}</TitleTag>
        <p class="meta reviewed-card-author">{author}</p>
        <div class="reviewed-card-line">
          {displayedRatingText && (
            <>
              <span
                class="reviewed-card-rating"
                role="img"
                aria-label={displayedRatingLabel ?? undefined}
              >
                {displayedRatingText}
              </span>
              <span class="reviewed-card-divider" aria-hidden="true">·</span>
            </>
          )}
          <span class="reviewed-card-status">{finishedLabel}</span>
        </div>
        {tags.length > 0 && (
          <div class="tag-row reviewed-tag-row">
            {tags.slice(0, 2).map((tag) => <span class="tag">{tag}</span>)}
          </div>
        )}
      </div>
    </>
  ) : (
    <>
      {shouldUseImage ? (
        <img src={cover ?? undefined} alt={`Cover of ${title}`} class="book-cover" loading="lazy" />
      ) : (
        <div class:list={placeholderClasses} style={`background: ${coverGradient}`}>
          <span>{title.charAt(0)}</span>
        </div>
      )}
      <div class="book-info">
        <TitleTag>{title}</TitleTag>
        <p class="meta">{author}</p>
        {variant === 'reading' && series && (
          <p class="series-label">{series} #{seriesNumber}</p>
        )}
        {(variant === 'reading' || variant === 'dnf') && mood && <p class="mood-line">{mood}</p>}
        {variant === 'reading' && tags.length > 0 && (
          <div class="tag-row">
            {tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
          </div>
        )}
      </div>
    </>
  )}
</a>

<style>
  .book-card {
    display: flex;
    gap: var(--space-4);
    text-decoration: none;
    color: inherit;
  }

  .book-cover {
    width: 80px;
    height: 120px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    box-shadow: var(--shadow-sm);
  }

  .book-cover-placeholder {
    width: 80px;
    height: 120px;
    flex-shrink: 0;
    background: linear-gradient(135deg, var(--color-sage-light), var(--color-sage));
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-style: italic;
    color: white;
    box-shadow: var(--shadow-sm);
  }

  .book-cover-placeholder.wishlist {
    background: linear-gradient(135deg, var(--color-gold-light), var(--color-gold));
  }

  .book-cover-placeholder.dnf {
    background: var(--gradient-dnf-cover);
    opacity: 1;
  }

  .book-info h4 {
    font-size: var(--text-md);
    margin-bottom: var(--space-1);
  }

  .meta {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    font-style: italic;
    margin-bottom: var(--space-1);
  }

  .mood-line {
    font-style: italic;
    font-size: var(--text-xs);
    color: var(--color-sage-dark);
    margin-bottom: var(--space-2);
  }

  .series-label {
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-terracotta);
    margin-bottom: var(--space-1);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .reviewed-card {
    --reviewed-cover-width: 56px;
    --reviewed-cover-height: 84px;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4);
    min-height: 100%;
  }

  .reviewed-card-figure {
    flex-shrink: 0;
  }

  .reviewed-book-cover,
  .reviewed-book-cover-placeholder {
    width: var(--reviewed-cover-width);
    height: var(--reviewed-cover-height);
    border: 1px solid rgba(200, 152, 78, 0.14);
  }

  .reviewed-book-cover-placeholder {
    font-size: 1.9rem;
  }

  .reviewed-card-copy {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .reviewed-card-title {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.06;
    color: var(--color-ink);
    font-style: normal;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .reviewed-card-author {
    margin: 0;
    font-style: normal;
  }

  .reviewed-card-line {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin: 0;
    font-family: var(--font-accent);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .reviewed-card-rating {
    color: var(--color-gold);
    letter-spacing: 0.14em;
  }

  .reviewed-card-divider {
    color: rgba(200, 152, 78, 0.6);
  }

  .reviewed-tag-row {
    margin-top: auto;
    padding-top: var(--space-2);
  }

  .dnf-card {
    opacity: 0.8;
  }

  @media (max-width: 720px) {
    .reviewed-card {
      --reviewed-cover-width: 60px;
      --reviewed-cover-height: 90px;
    }
  }
</style>
