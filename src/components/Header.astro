---
// Header component — gradient banner with botanical personality
// Navigation lives in the left sidebar now, so header is purely branding
---

<header class="site-header">
  <div class="header-inner">
    <div class="header-deco float-item" aria-hidden="true">✦ ❧ ✦</div>
    <a href="/" class="site-name">Marihella</a>
    <p class="site-tagline">books · plants · wanderings · recipes</p>
    <div class="header-deco float-item" aria-hidden="true">✦ ❧ ✦</div>
  </div>
</header>

<style>
  .site-header {
    background: linear-gradient(135deg, var(--color-sage-dark) 0%, var(--color-sage) 40%, var(--color-gold) 100%);
    border-bottom: 4px solid var(--color-ink);
    padding: var(--space-6) var(--space-8);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  /* Diagonal stripe texture overlay */
  .site-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      45deg,
      rgba(255, 255, 255, 0.06) 0px,
      rgba(255, 255, 255, 0.06) 2px,
      transparent 2px,
      transparent 16px
    );
    pointer-events: none;
  }

  .header-inner {
    position: relative;
    z-index: 1;
  }

  .header-deco {
    color: rgba(255, 255, 255, 0.5);
    font-size: var(--text-sm);
    letter-spacing: 0.5em;
    margin: var(--space-1) 0;
    user-select: none;
  }

  .site-name {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-style: italic;
    color: var(--color-cream);
    text-decoration: none;
    letter-spacing: 0.04em;
    display: block;
    text-shadow: 1px 2px 4px rgba(44, 24, 16, 0.3);
    transition: color 0.2s;
  }
  .site-name:hover { color: #fff; }

  .site-tagline {
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(253, 248, 240, 0.75);
    margin: var(--space-1) 0 0;
    max-width: none;
  }

  @media (max-width: 600px) {
    .site-header { padding: var(--space-4) var(--space-4); }
    .site-name { font-size: var(--text-2xl); }
    .header-deco { display: none; }
  }
</style>
