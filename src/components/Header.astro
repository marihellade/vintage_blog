---
// Header component — dark academia banner
// Salem the cat with golden glow + sleeping dragon with hanging tail
---

<header class="site-header">
  <div class="header-inner">
    <div class="header-deco float-item" aria-hidden="true">✦ ❧ ✦</div>
    <a href="/" class="site-name">Marihella</a>
    <p class="site-tagline">books · plants · wanderings · recipes</p>
    <div class="header-deco float-item" aria-hidden="true">✦ ❧ ✦</div>
  </div>

  <!-- Salem the cat — running with a warm golden glow -->
  <div class="salem" aria-hidden="true">
    <svg viewBox="0 0 64 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="salem-svg">
      <ellipse cx="30" cy="26" rx="14" ry="8" fill="#1a1a1a"/>
      <circle cx="46" cy="20" r="7" fill="#1a1a1a"/>
      <polygon points="41,14 43,7 46,13" fill="#1a1a1a"/>
      <polygon points="47,13 50,6 52,12" fill="#1a1a1a"/>
      <polygon points="42,13 43.5,9 45,13" fill="#3a2a2e" opacity="0.6"/>
      <polygon points="48,12 49.5,8 51,12" fill="#3a2a2e" opacity="0.6"/>
      <ellipse cx="44" cy="19.5" rx="1.8" ry="2" fill="#a3d94e"/>
      <ellipse cx="49" cy="19.5" rx="1.8" ry="2" fill="#a3d94e"/>
      <ellipse cx="44.2" cy="19.5" rx="0.8" ry="1.8" fill="#111"/>
      <ellipse cx="49.2" cy="19.5" rx="0.8" ry="1.8" fill="#111"/>
      <circle cx="43.5" cy="18.8" r="0.5" fill="white" opacity="0.9"/>
      <circle cx="48.5" cy="18.8" r="0.5" fill="white" opacity="0.9"/>
      <ellipse cx="46.5" cy="22" rx="0.8" ry="0.5" fill="#444"/>
      <line x1="43" y1="21" x2="36" y2="19.5" stroke="#888" stroke-width="0.5"/>
      <line x1="43" y1="22" x2="36" y2="22" stroke="#888" stroke-width="0.5"/>
      <line x1="50" y1="21" x2="57" y2="19.5" stroke="#888" stroke-width="0.5"/>
      <line x1="50" y1="22" x2="57" y2="22" stroke="#888" stroke-width="0.5"/>
      <path d="M16 24 Q8 22 6 16 Q4 10 8 6" stroke="#1a1a1a" stroke-width="3.5" stroke-linecap="round" fill="none"/>
      <line x1="38" y1="32" x2="42" y2="38" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round"/>
      <line x1="34" y1="33" x2="30" y2="38" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round"/>
      <line x1="22" y1="32" x2="18" y2="38" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round"/>
      <line x1="26" y1="33" x2="30" y2="39" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round"/>
      <circle cx="42" cy="38.5" r="1.2" fill="#1a1a1a"/>
      <circle cx="30" cy="38.5" r="1.2" fill="#1a1a1a"/>
      <circle cx="18" cy="38.5" r="1.2" fill="#1a1a1a"/>
      <circle cx="30" cy="39.5" r="1.2" fill="#1a1a1a"/>
    </svg>
  </div>

  <!-- Dragon perched on the right — tail hangs below the header ledge -->
  <div class="header-dragon" aria-hidden="true">
    <svg viewBox="0 0 260 280" class="header-dragon__svg" xmlns="http://www.w3.org/2000/svg" fill="none">
      <defs>
        <linearGradient id="dragonBody" x1="74" y1="54" x2="194" y2="130" gradientUnits="userSpaceOnUse">
          <stop offset="0" stop-color="#3D5A40"/>
          <stop offset="1" stop-color="#243A28"/>
        </linearGradient>
        <linearGradient id="dragonWing" x1="132" y1="56" x2="214" y2="104" gradientUnits="userSpaceOnUse">
          <stop offset="0" stop-color="#516C50"/>
          <stop offset="1" stop-color="#2A3F2D"/>
        </linearGradient>
        <linearGradient id="dragonBelly" x1="104" y1="74" x2="150" y2="112" gradientUnits="userSpaceOnUse">
          <stop offset="0" stop-color="#7D9777"/>
          <stop offset="1" stop-color="#5D735B"/>
        </linearGradient>
        <linearGradient id="dragonTailGrad" x1="85" y1="159" x2="88" y2="276" gradientUnits="userSpaceOnUse">
          <stop offset="0" stop-color="#3D5A40"/>
          <stop offset="1" stop-color="#1A2B1C"/>
        </linearGradient>
        <radialGradient id="aura" cx="0" cy="0" r="1" gradientUnits="userSpaceOnUse" gradientTransform="translate(162 82) rotate(90) scale(64 88)">
          <stop offset="0" stop-color="#B79A5A" stop-opacity="0.18"/>
          <stop offset="1" stop-color="#B79A5A" stop-opacity="0"/>
        </radialGradient>
        <filter id="dragonShadow" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="0" dy="4" stdDeviation="4" flood-color="#1D281E" flood-opacity="0.18"/>
        </filter>
      </defs>

      <!-- soft halo -->
      <ellipse cx="164" cy="86" rx="86" ry="56" fill="url(#aura)"/>
      <path d="M78 92C93 57 127 34 171 34C203 34 227 45 242 64"
            stroke="#B79A5A" stroke-width="1.6" stroke-linecap="round" opacity="0.42"/>
      <path d="M84 108C97 129 124 142 161 142C194 142 220 132 236 114"
            stroke="#B79A5A" stroke-width="1.4" stroke-linecap="round" opacity="0.3"/>

      <g filter="url(#dragonShadow)">

        <!-- tail — coil + hanging portion below header ledge -->
        <path d="M85 111
                 C63 118 53 132 58 145
                 C62 155 77 157 90 151
                 C101 146 103 136 95 129
                 C87 122 74 123 64 129
                 C80 117 96 120 106 128
                 C117 136 117 151 105 159
                 C100 168 96 182 92 198
                 C88 214 90 230 96 244
                 C100 256 96 268 88 276"
              stroke="url(#dragonTailGrad)"
              stroke-width="13"
              stroke-linecap="round"
              stroke-linejoin="round"/>

        <!-- tail belly highlight — coil portion -->
        <path d="M88 112
                 C69 118 61 131 65 142
                 C68 149 80 150 89 145
                 C96 141 97 134 91 129"
              stroke="#89A286"
              stroke-width="4.5"
              stroke-linecap="round"
              opacity="0.32"/>

        <!-- tail belly highlight — hanging portion -->
        <path d="M97 162
                 C94 171 92 185 90 200
                 C88 216 90 228 95 242"
              stroke="#89A286"
              stroke-width="3.5"
              stroke-linecap="round"
              opacity="0.25"/>

        <!-- tail tip — spade shape -->
        <ellipse cx="86" cy="279" rx="5" ry="8" fill="#1E3020" transform="rotate(-18 86 279)"/>
        <ellipse cx="92" cy="277" rx="3.5" ry="6" fill="#243A28" transform="rotate(-10 92 277)" opacity="0.6"/>

        <!-- rear wing / hidden wing hint -->
        <path d="M116 84
                 C94 70 86 51 93 43
                 C102 34 119 45 131 66
                 C124 74 119 80 116 84Z"
              fill="#314A35"
              opacity="0.42"/>

        <!-- body -->
        <ellipse cx="138" cy="98" rx="49" ry="31" fill="url(#dragonBody)"/>
        <ellipse cx="133" cy="100" rx="28" ry="16" fill="url(#dragonBelly)" opacity="0.95"/>

        <!-- scale ridges -->
        <path d="M110 78C116 76 121 75 126 76" stroke="#89A286" stroke-width="2" stroke-linecap="round" opacity="0.45"/>
        <path d="M125 73C132 71 138 71 144 73" stroke="#89A286" stroke-width="2" stroke-linecap="round" opacity="0.42"/>
        <path d="M141 74C148 73 154 74 160 77" stroke="#89A286" stroke-width="2" stroke-linecap="round" opacity="0.35"/>

        <!-- folded front wing -->
        <path d="M142 81
                 C171 54 203 48 213 58
                 C219 64 214 76 201 88
                 C189 98 172 105 152 109
                 C147 100 144 90 142 81Z"
              fill="url(#dragonWing)"/>
        <path d="M149 82C175 62 196 60 208 65"
              stroke="#B79A5A" stroke-width="1.4" stroke-linecap="round" opacity="0.4"/>
        <path d="M150 92C172 76 189 74 199 77"
              stroke="#8C7256" stroke-width="1.1" stroke-linecap="round" opacity="0.34"/>

        <!-- neck -->
        <path d="M164 77 C171 68 180 61 189 57 C196 54 203 55 206 60"
              stroke="url(#dragonBody)" stroke-width="17" stroke-linecap="round"/>
        <path d="M163 81 C171 73 179 67 186 64"
              stroke="#8AA488" stroke-width="5" stroke-linecap="round" opacity="0.32"/>

        <!-- head -->
        <ellipse cx="211" cy="60" rx="18" ry="14" fill="url(#dragonBody)"/>
        <path d="M221 61C229 61 235 66 235 72C230 74 223 74 217 71C216 67 217 63 221 61Z" fill="#2B412E"/>
        <path d="M202 60C206 57 211 56 216 58" stroke="#1A261D" stroke-width="1.2" opacity="0.5"/>

        <!-- closed eye — sleeping crescent (fades out when dragon stirs) -->
        <g class="dragon-eye-closed">
          <path d="M208 59C211 56 215 56 218 59"
                stroke="#B79A5A" stroke-width="1.8" stroke-linecap="round"/>
        </g>

        <!-- open eye — slit iris (fades in when Salem jumps over) -->
        <g class="dragon-eye-open">
          <ellipse cx="213" cy="58" rx="5.5" ry="4" fill="#3A5A3E"/>
          <ellipse cx="213" cy="58" rx="1.4" ry="3.2" fill="#111D13"/>
          <circle  cx="211.5" cy="56.5" r="0.9" fill="white" opacity="0.8"/>
          <ellipse cx="213" cy="58" rx="7" ry="5.5" fill="none"
                   stroke="#C8984E" stroke-width="0.6" opacity="0.45"/>
        </g>

        <!-- golden glow around eye when awake -->
        <ellipse class="dragon-wake-glow" cx="213" cy="56" rx="18" ry="12"
                 fill="#C8984E" opacity="0"/>

        <!-- horns -->
        <path d="M202 50C198 42 199 35 205 28" stroke="#B79A5A" stroke-width="2.5" stroke-linecap="round"/>
        <path d="M212 48C212 40 216 33 223 27" stroke="#B79A5A" stroke-width="2.2" stroke-linecap="round"/>
        <path d="M197 58C191 54 189 48 191 43" stroke="#6E866A" stroke-width="2" stroke-linecap="round"/>

        <!-- claws -->
        <path d="M110 124L105 131" stroke="#B79A5A" stroke-width="2.2" stroke-linecap="round"/>
        <path d="M116 125L112 133" stroke="#B79A5A" stroke-width="2" stroke-linecap="round"/>
        <path d="M168 121L173 129" stroke="#B79A5A" stroke-width="2.2" stroke-linecap="round"/>
        <path d="M162 123L166 131" stroke="#B79A5A" stroke-width="2" stroke-linecap="round"/>

        <!-- breath curl — animated -->
        <path class="dragon-breath"
              d="M234 55
                 C243 49 246 42 243 36
                 C239 30 230 31 227 38
                 C225 44 229 49 235 49
                 C243 49 247 43 248 38"
              stroke="#D6C18D"
              stroke-width="1.6"
              stroke-linecap="round"
              opacity="0.55"/>

      </g>
    </svg>
  </div>
</header>

<style>
  .site-header {
    background:
      linear-gradient(to bottom, rgba(200, 152, 78, 0.07), rgba(0, 0, 0, 0)),
      linear-gradient(180deg, #0A1508 0%, #111308 55%, #181408 100%);
    border-bottom: 2px solid var(--color-gold-light);
    padding: var(--space-6) var(--space-8);
    text-align: center;
    position: relative;
    z-index: 2;
    overflow: visible;
    isolation: isolate;
  }

  /* Subtle amber diagonal stripe */
  .site-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      rgba(200, 152, 78, 0.04) 0,
      rgba(200, 152, 78, 0.04) 2px,
      transparent 2px,
      transparent 14px
    );
    pointer-events: none;
    z-index: 0;
  }

  .header-inner {
    position: relative;
    z-index: 2;
  }

  .header-deco {
    color: rgba(237, 224, 200, 0.4);
    font-size: var(--text-sm);
    letter-spacing: 0.5em;
    margin: var(--space-1) 0;
    user-select: none;
  }

  .site-name {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-style: italic;
    color: var(--color-cream);
    text-decoration: none;
    letter-spacing: 0.04em;
    display: block;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.6), 0 0 40px rgba(200, 152, 78, 0.18);
    transition: color 0.2s;
  }
  .site-name:hover { color: #fff; }

  .site-tagline {
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(237, 224, 200, 0.55);
    margin: var(--space-1) 0 0;
    max-width: none;
  }

  /* --- Salem — golden glow + jumps over the dragon at ~75-85% of each run ---
     Two animations on the container:
       salem-run  → horizontal (left only, linear)
       salem-leap → vertical arc (transform only, ease-in-out)
     They share the same 12s duration so they stay in sync.
     The bounce stays on the inner SVG and is separate. */
  .salem {
    position: absolute;
    bottom: 6px;
    width: 48px;
    height: 30px;
    z-index: 3;
    animation:
      salem-run  12s linear     infinite,
      salem-leap 12s ease-in-out infinite;
    filter:
      drop-shadow(0 0 5px rgba(200, 152, 78, 0.9))
      drop-shadow(0 0 10px rgba(200, 152, 78, 0.4));
  }

  .salem-svg {
    width: 100%;
    height: 100%;
    animation: salem-bounce 0.35s ease-in-out infinite;
  }

  /* Horizontal travel only — no transform here to avoid conflict with salem-leap */
  @keyframes salem-run {
    0%   { left: -60px; }
    100% { left: calc(100% + 60px); }
  }

  /* Vertical arc — fallback for before JS runs (tuned for ~1920px wide screens).
     JavaScript below overwrites this with exact values for every viewport size. */
  @keyframes salem-leap {
    0%,  82%  { transform: translateY(0px)   rotate(0deg);   }
    88%       { transform: translateY(-80px) rotate(-20deg); }
    94%, 100% { transform: translateY(0px)   rotate(0deg);   }
  }

  @keyframes salem-bounce {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-3px); }
  }

  .site-header:hover .salem,
  .site-header:hover .salem-svg {
    animation-play-state: paused;
  }

  /* --- Dragon — claws rest on the header border, tail hangs below ---
     The claw tips sit at y≈131 of the 280-unit SVG (46.8% from top).
     bottom: -Xpx offsets the SVG so that 46.8% point aligns with the
     header's bottom border, anchoring the dragon to the ledge. */
  .header-dragon {
    position: absolute;
    right: clamp(0.75rem, 2vw, 2rem);
    bottom: -137px;     /* at 240px wide: SVG is 258px tall, 121px above claws → 137px below */
    width: min(240px, 24vw);
    aspect-ratio: 260 / 280;
    pointer-events: none;
    z-index: 1;
    opacity: 0.94;
  }

  .header-dragon__svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .dragon-breath {
    animation: dragon-breath 4.2s ease-in-out infinite;
    transform-origin: 238px 45px;
  }

  @keyframes dragon-breath {
    0%, 100% { opacity: 0.2; transform: translateY(0) scale(0.98); }
    50%       { opacity: 0.62; transform: translateY(-2px) scale(1.02); }
  }

  @media (max-width: 900px) {
    .header-dragon {
      width: min(180px, 32vw);
      right: 0.5rem;
      bottom: -103px;   /* at 180px wide: SVG 194px tall, 91px above claws → 103px below */
      opacity: 0.88;
    }
  }

  @media (max-width: 640px) {
    .header-dragon {
      width: 130px;
      right: 0.35rem;
      bottom: -74px;    /* at 130px wide: SVG 140px tall, 66px above claws → 74px below */
      opacity: 0.78;
    }
  }

  @media (max-width: 600px) {
    .site-header { padding: var(--space-4) var(--space-4); }
    .site-name { font-size: var(--text-2xl); }
    .header-deco { display: none; }
    .salem { width: 36px; height: 22px; }
  }

  /* --- Dragon wake --- */
  .dragon-eye-closed {
    animation: dragon-eye-close-anim 12s ease-in-out infinite;
  }
  .dragon-eye-open {
    animation: dragon-eye-open-anim 12s ease-in-out infinite;
  }
  .dragon-wake-glow {
    animation: dragon-wake-glow-anim 12s ease-in-out infinite;
  }

  /* CSS fallbacks — JS overrides with exact screen-measured percentages */
  @keyframes dragon-eye-close-anim {
    0%, 80%   { opacity: 1; }
    86%       { opacity: 0; }
    94%, 100% { opacity: 1; }
  }
  @keyframes dragon-eye-open-anim {
    0%, 80%   { opacity: 0; }
    86%       { opacity: 1; }
    94%, 100% { opacity: 0; }
  }
  @keyframes dragon-wake-glow-anim {
    0%, 80%   { opacity: 0;    }
    88%       { opacity: 0.12; }
    94%, 100% { opacity: 0;    }
  }

  @media (prefers-reduced-motion: reduce) {
    .salem { display: none; }
    .dragon-breath { animation: none; }
    .dragon-eye-closed { animation: none; opacity: 1; }
    .dragon-eye-open   { animation: none; opacity: 0; }
    .dragon-wake-glow  { animation: none; opacity: 0; }
  }
</style>

<script>
  (function () {
    const header = document.querySelector('.site-header');
    const dragon = document.querySelector('.header-dragon');
    if (!header || !dragon) return;
    let styleEl = null;
    function recalc() {
      if (window.getComputedStyle(dragon).display === 'none') return;
      const hw = header.offsetWidth;
      const dr = dragon.getBoundingClientRect();
      const hr = header.getBoundingClientRect();
      const totalTravel = hw + 120;
      const dLeft  = dr.left  - hr.left;
      const dRight = dr.right - hr.left;
      const dMid   = (dLeft + dRight) / 2;
      // Jump height: measure how far Salem's top needs to travel to clear the dragon's highest point
      // Salem rests at bottom:6px, height:30px → top is at hr.bottom - 36
      // Dragon top (horn tips) is at dr.top. Add 12px clearance above that.
      const salemRestTop = hr.bottom - 36;
      const jumpHeight   = Math.max(70, Math.round(salemRestTop - dr.top + 12));

      const liftPct  = ((dLeft  - 30 + 60) / totalTravel * 100).toFixed(2);
      const peakPct  = ((dMid        + 60) / totalTravel * 100).toFixed(2);
      const landPct  = ((dRight + 20 + 60) / totalTravel * 100).toFixed(2);
      // Eye opens exactly when Salem lifts; stays open until she's well past, then closes
      const gazePct  = Math.min(98, parseFloat(landPct) + 7 ).toFixed(2);
      const sleepPct = Math.min(99, parseFloat(gazePct) + 3 ).toFixed(2);

      if (!styleEl) {
        styleEl = document.createElement('style');
        document.head.appendChild(styleEl);
      }
      styleEl.textContent = `
@keyframes salem-leap {
  0%, ${liftPct}%   { transform: translateY(0px)          rotate(0deg);   }
  ${peakPct}%       { transform: translateY(-${jumpHeight}px) rotate(-20deg); }
  ${landPct}%, 100% { transform: translateY(0px)          rotate(0deg);   }
}
@keyframes dragon-eye-close-anim {
  0%, ${liftPct}%   { opacity: 1; }
  ${peakPct}%       { opacity: 0; }
  ${gazePct}%       { opacity: 0; }
  ${sleepPct}%, 100%{ opacity: 1; }
}
@keyframes dragon-eye-open-anim {
  0%, ${liftPct}%   { opacity: 0; }
  ${peakPct}%       { opacity: 1; }
  ${gazePct}%       { opacity: 1; }
  ${sleepPct}%, 100%{ opacity: 0; }
}
@keyframes dragon-wake-glow-anim {
  0%, ${liftPct}%   { opacity: 0;    }
  ${peakPct}%       { opacity: 0.12; }
  ${gazePct}%       { opacity: 0.12; }
  ${sleepPct}%, 100%{ opacity: 0;    }
}`;
    }
    const init = () => requestAnimationFrame(() => requestAnimationFrame(recalc));
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(recalc, 150);
    });
  })();
</script>
