---
// Sparkle star cursor — glittering trail follows the mouse
// Automatically hidden on touch devices (see global.css)
---

<div id="cursor-dot" aria-hidden="true"></div>
<div id="spark-container" aria-hidden="true"></div>

<style>
  #spark-container {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
    overflow: hidden;
  }

  #cursor-dot {
    position: fixed;
    width: 10px;
    height: 10px;
    background: radial-gradient(circle, var(--color-cream) 30%, var(--color-gold) 100%);
    border-radius: 50%;
    pointer-events: none;
    z-index: 10000;
    transform: translate(-50%, -50%);
    transition: width 0.1s ease, height 0.1s ease;
    will-change: left, top;
    box-shadow: 0 0 6px rgba(200, 152, 78, 0.7), 0 0 12px rgba(200, 152, 78, 0.3);
  }

  #cursor-dot.hovering {
    width: 14px;
    height: 14px;
    background: radial-gradient(circle, white 20%, var(--color-terracotta) 100%);
    box-shadow: 0 0 10px rgba(212, 107, 82, 0.8), 0 0 20px rgba(212, 107, 82, 0.3);
  }

  .spark {
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    user-select: none;
    line-height: 1;
    transform: translate(-50%, -50%);
    animation: spark-rise var(--dur, 0.9s) ease-out forwards;
  }

  @keyframes spark-rise {
    0% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1) rotate(var(--r0, 0deg));
    }
    60% {
      opacity: 0.7;
    }
    100% {
      opacity: 0;
      transform:
        translate(calc(-50% + var(--dx, 0px)), calc(-50% + var(--dy, -28px)))
        scale(0.15)
        rotate(var(--r1, 120deg));
    }
  }
</style>

<script>
  const dot = document.getElementById('cursor-dot')!;
  const sparkBox = document.getElementById('spark-container')!;
  const rootStyles = getComputedStyle(document.documentElement);
  const readToken = (name: string) => rootStyles.getPropertyValue(name).trim();

  // Star/sparkle character set — visually distinct, small
  const SHAPES = ['✦', '✧', '★', '⋆', '✫', '✬', '✭', '✮', '✯', '✦', '✧', '⋆'];
  // Warm gold / sage / cream palette
  const COLORS = [
    readToken('--color-cream'),
    readToken('--color-gold'),
    readToken('--color-cursor-gold-soft'),
    readToken('--color-sage-dark'),
    readToken('--color-cursor-cream-soft'),
    readToken('--color-terracotta'),
    readToken('--color-cursor-gold-muted'),
    'white',
  ];

  const INTERVAL = 35; // ms between sparks — denser trail
  let lastSpawn = 0;

  document.addEventListener('mousemove', (e) => {
    dot.style.left = e.clientX + 'px';
    dot.style.top  = e.clientY + 'px';

    const now = Date.now();
    if (now - lastSpawn > INTERVAL) {
      spawnSpark(e.clientX, e.clientY);
      lastSpawn = now;
    }
  });

  document.addEventListener('mouseover', (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('a, button, [role="button"], input, textarea, select')) {
      dot.classList.add('hovering');
    }
  });
  document.addEventListener('mouseout', (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('a, button, [role="button"], input, textarea, select')) {
      dot.classList.remove('hovering');
    }
  });

  function spawnSpark(x: number, y: number) {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const el = document.createElement('span');
    el.className = 'spark';
    el.textContent = SHAPES[Math.floor(Math.random() * SHAPES.length)];

    // Position with a little spread around the cursor
    el.style.left = (x + (Math.random() - 0.5) * 14) + 'px';
    el.style.top  = (y + (Math.random() - 0.5) * 14) + 'px';
    el.style.color = COLORS[Math.floor(Math.random() * COLORS.length)];
    el.style.fontSize = (9 + Math.random() * 10) + 'px';

    // Each spark drifts in a random upward-biased direction
    const angle = (Math.random() * 160 + 190) * (Math.PI / 180); // mostly upward (200–350°)
    const dist  = 20 + Math.random() * 30;
    el.style.setProperty('--dx',  (Math.cos(angle) * dist).toFixed(1) + 'px');
    el.style.setProperty('--dy',  (Math.sin(angle) * dist).toFixed(1) + 'px');
    el.style.setProperty('--r0',  (Math.random() * 60 - 30) + 'deg');
    el.style.setProperty('--r1',  (Math.random() * 200 - 100 + 120) + 'deg');
    el.style.setProperty('--dur', (0.7 + Math.random() * 0.6) + 's');

    sparkBox.appendChild(el);
    el.addEventListener('animationend', () => el.remove(), { once: true });
  }
</script>
