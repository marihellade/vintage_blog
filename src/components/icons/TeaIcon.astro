---
interface Props { class?: string; }
const { class: className = '' } = Astro.props;
---
<span class:list={['icon-tea', className]} aria-hidden="true">
  <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- steam wisps -->
    <path class="steam" d="M12 8 Q10 5 12 2" stroke="#7A9E7E" stroke-width="1" stroke-linecap="round" fill="none" opacity="0"/>
    <path class="steam steam-2" d="M16 7 Q18 4 16 1" stroke="#7A9E7E" stroke-width="1" stroke-linecap="round" fill="none" opacity="0"/>
    <path class="steam steam-3" d="M20 8 Q18 5 20 2" stroke="#7A9E7E" stroke-width="1" stroke-linecap="round" fill="none" opacity="0"/>
    <!-- cup -->
    <path d="M6 12 L8 28 Q8 30 10 30 L22 30 Q24 30 24 28 L26 12 Z" fill="#F7F0E1" stroke="#B8934A" stroke-width="0.8"/>
    <!-- tea liquid -->
    <path d="M8 14 L9.5 26 Q9.5 28 11 28 L21 28 Q22.5 28 22.5 26 L24 14 Z" fill="#D4853A" opacity="0.35"/>
    <!-- handle -->
    <path d="M26 15 Q30 15 30 20 Q30 25 26 25" stroke="#B8934A" stroke-width="1.2" fill="none"/>
    <!-- decorative band -->
    <line x1="7" y1="14" x2="25" y2="14" stroke="#B8934A" stroke-width="0.6"/>
    <!-- tiny flower on cup -->
    <circle cx="16" cy="21" r="1.5" fill="#D4853A" opacity="0.4"/>
    <circle cx="16" cy="21" r="0.6" fill="#B8934A"/>
  </svg>
</span>
