---
interface Props { class?: string; }
const { class: className = '' } = Astro.props;
---
<span class:list={['icon-quill', className]} aria-hidden="true">
  <svg viewBox="0 0 24 32" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g class="quill-body">
      <!-- feather vane -->
      <path d="M18 2 Q14 8 10 14 Q8 18 6 22 Q10 16 14 10 Q16 6 18 2" fill="#4A7550" opacity="0.6"/>
      <path d="M18 2 Q20 8 16 14 Q14 18 12 22 Q14 16 16 10 Q18 6 18 2" fill="#7A9E7E" opacity="0.5"/>
      <!-- shaft -->
      <path d="M18 2 L8 28" stroke="#B8934A" stroke-width="0.8"/>
      <!-- nib -->
      <path d="M8 28 L6 32 L9 29 Z" fill="#4A3728"/>
      <!-- midrib -->
      <path d="M18 2 Q14 10 10 18" stroke="#4A7550" stroke-width="0.4" fill="none"/>
      <!-- ink dot -->
      <circle cx="6.5" cy="31" r="1" fill="#2C1810" opacity="0.5"/>
    </g>
  </svg>
</span>
