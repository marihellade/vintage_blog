---
interface Props { class?: string; }
const { class: className = '' } = Astro.props;
---
<span class:list={['icon-potion', className]} aria-hidden="true">
  <svg viewBox="0 0 24 34" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- bottle body -->
    <path d="M6 14 Q4 16 4 20 L4 28 Q4 30 6 30 L18 30 Q20 30 20 28 L20 20 Q20 16 18 14 Z" fill="#7A9E7E" opacity="0.4" stroke="#4A7550" stroke-width="0.8"/>
    <!-- liquid -->
    <path d="M6 18 L6 28 Q6 29 7 29 L17 29 Q18 29 18 28 L18 18 Z" fill="#4A7550" opacity="0.5"/>
    <!-- neck -->
    <rect x="9" y="6" width="6" height="8" rx="0.5" fill="#F7F0E1" stroke="#B8934A" stroke-width="0.6"/>
    <!-- cork -->
    <rect x="9.5" y="3" width="5" height="4" rx="1" fill="#C4614A" opacity="0.7"/>
    <!-- bubbles -->
    <circle class="bubble" cx="10" cy="24" r="1" fill="#B5CEAC" opacity="0"/>
    <circle class="bubble bubble-2" cx="14" cy="26" r="0.7" fill="#B5CEAC" opacity="0"/>
    <circle class="bubble bubble-3" cx="12" cy="22" r="1.2" fill="#B5CEAC" opacity="0"/>
    <!-- label -->
    <rect x="7" y="20" width="10" height="6" rx="0.5" fill="#F7F0E1" opacity="0.7"/>
    <line x1="9" y1="22" x2="15" y2="22" stroke="#B8934A" stroke-width="0.4"/>
    <line x1="9" y1="24" x2="13" y2="24" stroke="#B8934A" stroke-width="0.4"/>
    <!-- shine -->
    <line x1="16" y1="16" x2="17" y2="22" stroke="white" stroke-width="0.5" opacity="0.4"/>
  </svg>
</span>
