---
interface Props { class?: string; delay?: number; }
const { class: className = '', delay = 0 } = Astro.props;
const delayClass = delay > 0 ? `delay-${delay}` : '';
---
<span class:list={['icon-star', delayClass, className]} aria-hidden="true">
  <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g class="star-body">
      <path d="M10 2 L11.5 7.5 L17 7.5 L12.5 11 L14 17 L10 13.5 L6 17 L7.5 11 L3 7.5 L8.5 7.5 Z" fill="#B8934A" opacity="0.85"/>
      <path d="M10 4 L11 7.5 L14.5 7.5 L11.5 10 L12.5 14 L10 12 L7.5 14 L8.5 10 L5.5 7.5 L9 7.5 Z" fill="#DEC48A"/>
    </g>
  </svg>
</span>
