---
interface Props { class?: string; }
const { class: className = '' } = Astro.props;
---
<span class:list={['icon-sprout', className]} aria-hidden="true">
  <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- soil -->
    <ellipse cx="14" cy="25" rx="8" ry="2.5" fill="#4A3728" opacity="0.5"/>
    <!-- stem -->
    <path d="M14 24 Q14 18 14 14" stroke="#4A7550" stroke-width="1.5" stroke-linecap="round"/>
    <!-- left leaf -->
    <g class="leaf-left">
      <path d="M14 18 Q8 15 6 10 Q10 11 14 16" fill="#7A9E7E"/>
      <path d="M14 17.5 Q10 14 8 11" stroke="#4A7550" stroke-width="0.4" fill="none"/>
    </g>
    <!-- right leaf -->
    <g class="leaf-right">
      <path d="M14 14 Q20 11 22 6 Q18 8 14 13" fill="#4A7550"/>
      <path d="M14 13.5 Q18 10 20 7" stroke="#2D5016" stroke-width="0.4" fill="none"/>
    </g>
    <!-- tiny bud -->
    <circle cx="14" cy="12" r="1.5" fill="#7A9E7E" opacity="0.7"/>
  </svg>
</span>
