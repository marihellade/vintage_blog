---
interface Props { class?: string; }
const { class: className = '' } = Astro.props;
---
<span class:list={['icon-book', className]} aria-hidden="true">
  <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Drop shadow for depth -->
    <rect x="6" y="5" width="19" height="23" rx="2" fill="#120820" opacity="0.25"/>

    <!-- Back cover (deep plum, visible as sliver at right) -->
    <rect x="5" y="4" width="19" height="23" rx="2" fill="#3A1565"/>

    <!-- Pages edge (right side) -->
    <rect x="22" y="6" width="2.5" height="19" rx="0.5" fill="#F0E8D5"/>
    <line x1="22" y1="9"  x2="24.5" y2="9"  stroke="#CBBF98" stroke-width="0.4"/>
    <line x1="22" y1="12" x2="24.5" y2="12" stroke="#CBBF98" stroke-width="0.4"/>
    <line x1="22" y1="15" x2="24.5" y2="15" stroke="#CBBF98" stroke-width="0.4"/>
    <line x1="22" y1="18" x2="24.5" y2="18" stroke="#CBBF98" stroke-width="0.4"/>
    <line x1="22" y1="21" x2="24.5" y2="21" stroke="#CBBF98" stroke-width="0.4"/>

    <!-- Front cover (medium purple) -->
    <rect x="5" y="4" width="18" height="23" rx="2" fill="#6B3FA0"/>
    <!-- Subtle highlight sheen on left half of cover -->
    <rect x="5" y="4" width="7" height="23" rx="2" fill="#9060C0" opacity="0.2"/>

    <!-- Ornate gold border frame on cover -->
    <rect x="7.5" y="6.5" width="12.5" height="18" rx="1.5" fill="none" stroke="#D4A832" stroke-width="0.85"/>
    <!-- Corner accent circles on frame -->
    <circle cx="8.7" cy="7.7" r="0.85" fill="#D4A832"/>
    <circle cx="19.3" cy="7.7" r="0.85" fill="#D4A832"/>
    <circle cx="8.7" cy="23.3" r="0.85" fill="#D4A832"/>
    <circle cx="19.3" cy="23.3" r="0.85" fill="#D4A832"/>

    <!-- 4-pointed star / sparkle ornament on cover -->
    <path class="star-sparkle"
      d="M14,10 L14.85,12.15 L17,13 L14.85,13.85 L14,16 L13.15,13.85 L11,13 L13.15,12.15 Z"
      fill="#D4A832"/>
    <!-- Tiny satellite sparkle dots -->
    <circle class="star-sparkle" cx="11.5" cy="10.8" r="0.6" fill="#D4A832" opacity="0.78" style="animation-delay:0.4s"/>
    <circle class="star-sparkle" cx="16.5" cy="10.3" r="0.6" fill="#D4A832" opacity="0.78" style="animation-delay:0.8s"/>

    <!-- Title lines (bottom of frame area) -->
    <line x1="9.5" y1="18.5" x2="18" y2="18.5" stroke="#D4A832" stroke-width="0.9" stroke-linecap="round" opacity="0.9"/>
    <line x1="10.5" y1="20.5" x2="17" y2="20.5" stroke="#D4A832" stroke-width="0.7" stroke-linecap="round" opacity="0.75"/>

    <!-- Spine (very dark purple, left strip) -->
    <rect x="5" y="4" width="3.5" height="23" rx="2" fill="#1E0845"/>
    <!-- Spine gold accent line -->
    <line x1="7.5" y1="7" x2="7.5" y2="24" stroke="#D4A832" stroke-width="0.7" stroke-linecap="round" opacity="0.8"/>

    <!-- Bookmark ribbon (dusty rose / mauve), pointed at bottom -->
    <path d="M19.5,4 L22,4 L22,11.5 L20.75,9.8 L19.5,11.5 Z" fill="#B87297"/>
    <!-- Bookmark sheen -->
    <line x1="20.4" y1="5" x2="20.4" y2="10.5" stroke="#D4A0BB" stroke-width="0.5" opacity="0.5"/>
  </svg>
</span>
