---
interface Props { class?: string; }
const { class: className = '' } = Astro.props;
---
<span class:list={['icon-book', className]} aria-hidden="true">
  <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- back cover -->
    <rect x="5" y="4" width="20" height="24" rx="1" fill="#4A7550"/>
    <!-- pages -->
    <rect x="7" y="5" width="17" height="22" rx="0.5" fill="#F7F0E1"/>
    <line x1="9" y1="10" x2="20" y2="10" stroke="#DEC48A" stroke-width="0.6"/>
    <line x1="9" y1="13" x2="18" y2="13" stroke="#DEC48A" stroke-width="0.6"/>
    <line x1="9" y1="16" x2="20" y2="16" stroke="#DEC48A" stroke-width="0.6"/>
    <line x1="9" y1="19" x2="17" y2="19" stroke="#DEC48A" stroke-width="0.6"/>
    <!-- turning page -->
    <rect class="page-turn" x="15" y="5" width="9" height="22" rx="0.5" fill="#FDF8F0" opacity="0.9"/>
    <!-- spine -->
    <rect x="5" y="4" width="3" height="24" rx="1" fill="#2D5016"/>
    <!-- gold detail on spine -->
    <line x1="6.5" y1="8" x2="6.5" y2="24" stroke="#B8934A" stroke-width="0.6"/>
  </svg>
</span>
