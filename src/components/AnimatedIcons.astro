---
// Animated decorative icons — cozy vintage apothecary style
// Use: <AnimatedBook />, etc. or import the whole set
---

<!-- Animated book with turning page -->
<Fragment>
  <!-- these are defined here so pages can reference the class names -->
</Fragment>

<style is:global>
  /* ============================================================
     ANIMATED ICONS — cozy vintage decorations
     ============================================================ */

  /* --- Animated book --- */
  .icon-book {
    display: inline-block;
    width: 28px;
    height: 28px;
    position: relative;
  }
  .icon-book svg { width: 100%; height: 100%; }
  .icon-book .page-turn {
    transform-origin: left center;
    animation: page-flip 3s ease-in-out infinite;
  }
  @keyframes page-flip {
    0%, 100% { transform: rotateY(0deg); }
    40%      { transform: rotateY(-160deg); }
    60%      { transform: rotateY(-160deg); }
  }

  /* --- Flickering candle --- */
  .icon-candle {
    display: inline-block;
    width: 20px;
    height: 32px;
  }
  .icon-candle svg { width: 100%; height: 100%; }
  .icon-candle .flame {
    transform-origin: bottom center;
    animation: flame-flicker 1.5s ease-in-out infinite alternate;
  }
  .icon-candle .flame-glow {
    animation: glow-pulse 1.5s ease-in-out infinite alternate;
  }
  @keyframes flame-flicker {
    0%   { transform: scaleX(1) scaleY(1) rotate(0deg); }
    25%  { transform: scaleX(0.85) scaleY(1.1) rotate(-3deg); }
    50%  { transform: scaleX(1.1) scaleY(0.9) rotate(2deg); }
    75%  { transform: scaleX(0.9) scaleY(1.05) rotate(-2deg); }
    100% { transform: scaleX(1) scaleY(1) rotate(1deg); }
  }
  @keyframes glow-pulse {
    0%   { opacity: 0.3; r: 8; }
    100% { opacity: 0.5; r: 10; }
  }

  /* --- Steaming tea cup --- */
  .icon-tea {
    display: inline-block;
    width: 28px;
    height: 28px;
  }
  .icon-tea svg { width: 100%; height: 100%; }
  .icon-tea .steam {
    animation: steam-rise 2.5s ease-in-out infinite;
    opacity: 0;
  }
  .icon-tea .steam-2 { animation-delay: 0.8s; }
  .icon-tea .steam-3 { animation-delay: 1.6s; }
  @keyframes steam-rise {
    0%   { opacity: 0; transform: translateY(0) scaleX(1); }
    30%  { opacity: 0.6; }
    100% { opacity: 0; transform: translateY(-10px) scaleX(1.5); }
  }

  /* --- Twinkling star --- */
  .icon-star {
    display: inline-block;
    width: 18px;
    height: 18px;
  }
  .icon-star svg { width: 100%; height: 100%; }
  .icon-star .star-body {
    animation: star-twinkle 2s ease-in-out infinite;
  }
  .icon-star.delay-1 .star-body { animation-delay: 0.5s; }
  .icon-star.delay-2 .star-body { animation-delay: 1.0s; }
  .icon-star.delay-3 .star-body { animation-delay: 1.5s; }
  @keyframes star-twinkle {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.3; transform: scale(0.7); }
  }

  /* --- Growing plant / sprout --- */
  .icon-sprout {
    display: inline-block;
    width: 24px;
    height: 24px;
  }
  .icon-sprout svg { width: 100%; height: 100%; }
  .icon-sprout .leaf-left {
    transform-origin: bottom center;
    animation: leaf-sway 3s ease-in-out infinite;
  }
  .icon-sprout .leaf-right {
    transform-origin: bottom center;
    animation: leaf-sway 3s ease-in-out infinite reverse;
  }
  @keyframes leaf-sway {
    0%, 100% { transform: rotate(0deg); }
    50%      { transform: rotate(-5deg); }
  }

  /* --- Floating feather / quill --- */
  .icon-quill {
    display: inline-block;
    width: 22px;
    height: 28px;
  }
  .icon-quill svg { width: 100%; height: 100%; }
  .icon-quill .quill-body {
    transform-origin: center;
    animation: quill-float 4s ease-in-out infinite;
  }
  @keyframes quill-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-3px) rotate(3deg); }
  }

  /* --- Potion bottle --- */
  .icon-potion {
    display: inline-block;
    width: 20px;
    height: 28px;
  }
  .icon-potion svg { width: 100%; height: 100%; }
  .icon-potion .bubble {
    animation: bubble-rise 2s ease-in infinite;
    opacity: 0;
  }
  .icon-potion .bubble-2 { animation-delay: 0.7s; }
  .icon-potion .bubble-3 { animation-delay: 1.4s; }
  @keyframes bubble-rise {
    0%   { opacity: 0; transform: translateY(0); }
    30%  { opacity: 0.7; }
    100% { opacity: 0; transform: translateY(-8px); }
  }

  /* --- Size variants --- */
  .icon-sm { transform: scale(0.75); }
  .icon-lg { transform: scale(1.4); }
  .icon-xl { transform: scale(1.8); }

  /* --- Reduced motion --- */
  @media (prefers-reduced-motion: reduce) {
    .icon-book .page-turn,
    .icon-candle .flame,
    .icon-candle .flame-glow,
    .icon-tea .steam,
    .icon-star .star-body,
    .icon-sprout .leaf-left,
    .icon-sprout .leaf-right,
    .icon-quill .quill-body,
    .icon-potion .bubble {
      animation: none !important;
      opacity: 1 !important;
    }
  }
</style>
