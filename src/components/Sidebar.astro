---
import { getCollection } from 'astro:content';
import AnimatedIcons from './AnimatedIcons.astro';
import BookIcon from './icons/BookIcon.astro';
import CandleIcon from './icons/CandleIcon.astro';
import StarIcon from './icons/StarIcon.astro';
import PotionIcon from './icons/PotionIcon.astro';
import QuillIcon from './icons/QuillIcon.astro';

const navLinks = [
  { href: '/',         label: 'Home',          icon: '✦' },
  { href: '/books',    label: 'Book Diary',    icon: '📖' },
  { href: '/plants',   label: 'Plant Journal', icon: '🌿' },
  { href: '/travel',   label: 'Travel',        icon: '✧' },
  { href: '/recipes',  label: 'Recipe Box',    icon: '🍞' },
  { href: '/about',    label: 'About',         icon: '❧' },
];

const currentPath = Astro.url.pathname;

const allBooks = await getCollection('books');
const currentlyReading = allBooks.filter(b => b.data.status === 'reading');

const quotes = [
  { text: "The cost of progress is always paid by someone.", source: "Blood Over Bright Haven" },
  { text: "The weakest rider with the strongest dragon still wins.", source: "Fourth Wing" },
  { text: "I solemnly swear that I am up to no good", source: "Harry Potter and the Prisoner of Azkaban" },
  { text: "Some places are more than places. They are doors.", source: "" },
];
const randomQuote = quotes[Math.floor(Math.random() * quotes.length)];
---

<AnimatedIcons />

<aside class="left-sidebar">

  <!-- Navigation widget -->
  <nav class="widget-box nav-widget" aria-label="Site navigation">
    <h4 class="widget-title"><span class="widget-icon" aria-hidden="true">❧</span> Navigate</h4>
    <ul class="nav-list">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['sidebar-nav-link', { active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
          >
            <span class="nav-icon" aria-hidden="true">{link.icon}</span>
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Currently reading with animated book -->
  {currentlyReading.length > 0 && (
    <div class="widget-box">
      <h4 class="widget-title"><BookIcon class="icon-sm" /> Reading Now</h4>
      <ul class="reading-list">
        {currentlyReading.map(book => (
          <li>
            <a href={`/books/${book.slug}`}>{book.data.title}</a>
            {book.data.series && <span class="reading-series">{book.data.series}</span>}
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- Quote widget with quill -->
  <div class="widget-box quote-widget">
    <h4 class="widget-title"><QuillIcon class="icon-sm" /> A thought</h4>
    <blockquote class="sidebar-quote">
      &ldquo;{randomQuote.text}&rdquo;
      {randomQuote.source && <cite>— {randomQuote.source}</cite>}
    </blockquote>
  </div>

  <!-- Candle decoration -->
  <div class="widget-box candle-widget">
    <div class="candle-row">
      <CandleIcon />
      <div class="candle-text">
        <p>burning the midnight oil</p>
        <div class="star-row">
          <StarIcon delay={1} />
          <StarIcon delay={2} />
          <StarIcon delay={3} />
        </div>
      </div>
      <CandleIcon />
    </div>
  </div>

  <!-- Mood badges -->
  <div class="widget-box">
    <h4 class="widget-title"><PotionIcon class="icon-sm" /> Mood</h4>
    <div class="mood-badges">
      <span class="mood-badge sage">📚 Book hoarder</span>
      <span class="mood-badge terra">🌿 Botanical enthusiast</span>
      <span class="mood-badge gold">☕ Tea enjoyer</span>
      <span class="mood-badge sage">🐉 Dragon lover</span>
      <span class="mood-badge terra">🌙 Night Reader</span>
    </div>
  </div>

</aside>

<style>
  .left-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: sticky;
    top: 80px;
  }

  /* --- Override widget-title for sidebar: match nav link readability --- */
  .widget-title {
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-sm);
  }

  /* --- Nav widget --- */
  .nav-widget {
    background: linear-gradient(160deg, #1E1A12 0%, #161A12 100%);
    border-color: var(--color-sage);
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav-list li { margin: 0; }

  .sidebar-nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    letter-spacing: 0;
    text-transform: none;
    text-decoration: none;
    color: var(--color-ink-soft);
    border-radius: var(--radius-sm);
    transition: background 0.15s, color 0.15s;
  }
  .sidebar-nav-link:hover,
  .sidebar-nav-link.active {
    background: var(--color-sage);
    color: white;
  }

  .nav-icon { font-style: normal; font-size: var(--text-sm); }

  /* --- Reading list --- */
  .reading-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .reading-list li {
    padding: var(--space-2) 0;
    border-bottom: 1px dotted var(--color-gold-light);
    margin: 0;
  }
  .reading-list li:last-child { border-bottom: none; }
  .reading-list a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    text-decoration: none;
    display: block;
  }
  .reading-series {
    font-size: var(--text-xs);
    color: var(--color-ink-soft);
    font-style: italic;
    display: block;
  }

  /* --- Quote widget --- */
  .sidebar-quote {
    border: none;
    background: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: normal;
    color: var(--color-ink-soft);
    line-height: 1.6;
  }
  .sidebar-quote cite {
    display: block;
    margin-top: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-gold);
    font-style: normal;
  }

  /* --- Candle widget --- */
  .candle-widget { text-align: center; }
  .candle-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }
  .candle-text p {
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-sm);
    color: var(--color-gold);
    margin: 0;
  }
  .star-row {
    display: flex;
    justify-content: center;
    gap: var(--space-1);
    margin-top: var(--space-1);
  }

  /* --- Mood badges --- */
  .mood-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .mood-badge {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0;
    text-transform: none;
    padding: 2px var(--space-2);
    border-radius: 999px;
    white-space: nowrap;
  }
  .mood-badge.sage {
    background: rgba(122, 158, 126, 0.2);
    color: var(--color-sage-dark);
    border: 1px solid var(--color-sage-light);
  }
  .mood-badge.terra {
    background: rgba(196, 97, 74, 0.15);
    color: var(--color-terracotta);
    border: 1px solid var(--color-terracotta-light);
  }
  .mood-badge.gold {
    background: rgba(184, 147, 74, 0.15);
    color: var(--color-gold);
    border: 1px solid var(--color-gold-light);
  }

  /* --- Responsive --- */
  @media (max-width: 900px) {
    .left-sidebar {
      position: static;
      order: -1;
    }
    .nav-widget { order: -1; }
    .nav-list {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-1);
    }
    .candle-widget { display: none; }
  }
</style>
