---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">

    <hr class="fancy" />

    <div class="footer-content">
      <p class="footer-name">Marihella</p>
      <p class="footer-byline">a small corner of the internet, tended with care</p>

      <div class="footer-links">
        <a href="/about">about</a>
        <span aria-hidden="true">·</span>
        <a href="/now">now</a>
        <span aria-hidden="true">·</span>
        <a href="/links">links</a>
        <span aria-hidden="true">·</span>
        <a href="/books">books</a>
        <span aria-hidden="true">·</span>
        <a href="/plants">plants</a>
        <span aria-hidden="true">·</span>
        <a href="/travel">travel</a>
        <span aria-hidden="true">·</span>
        <a href="/recipes">recipes</a>
      </div>

      <!-- 88x31 site button + web ring inspired element -->
      <div class="footer-buttons">
        <div class="site-button-88x31">
          <span class="btn-line">MARIHELLA</span>
          <span class="btn-sub">✦ est. 2026 ✦</span>
        </div>
      </div>

      <div class="web-ring">
        <span class="wr-arrow" aria-hidden="true">&larr;</span>
        <span class="wr-label">indie web ring</span>
        <span class="wr-arrow" aria-hidden="true">&rarr;</span>
      </div>

      <p class="footer-credit">
        &copy; {year} &mdash; made with quiet evenings and too much tea
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-12);
    background: var(--gradient-footer-surface);
    color: var(--color-ink);
    border-top: 2px solid var(--color-gold-light);
    padding: var(--space-8) var(--space-6);
  }

  .site-footer :global(hr.fancy) {
    background: linear-gradient(90deg, transparent, var(--color-sage), var(--color-gold), var(--color-sage), transparent);
    margin-bottom: var(--space-6);
  }

  .footer-inner {
    max-width: var(--page-max);
    margin: 0 auto;
    text-align: center;
  }

  .footer-name {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-style: italic;
    color: var(--color-cream);
    margin-bottom: var(--space-1);
    max-width: none;
  }

  .footer-byline {
    font-family: var(--font-body);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    margin-bottom: var(--space-4);
    max-width: none;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }
  .footer-links a {
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-sage-light);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--color-gold); }
  .footer-links span { color: var(--color-sage); opacity: 0.4; }

  /* --- 88x31 button --- */
  .footer-buttons {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-4);
  }

  .site-button-88x31 {
    width: 88px;
    height: 31px;
    background: linear-gradient(135deg, var(--color-sage-dark) 0%, var(--color-forest) 100%);
    border: 2px solid var(--color-gold);
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    cursor: default;
  }
  .btn-line {
    font-family: monospace;
    font-size: 0.45rem;
    font-weight: bold;
    letter-spacing: 0.15em;
    color: var(--color-cream);
    line-height: 1;
  }
  .btn-sub {
    font-family: monospace;
    font-size: 0.3rem;
    letter-spacing: 0.1em;
    color: var(--color-gold-light);
    line-height: 1;
  }

  /* --- Web ring --- */
  .web-ring {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-sage);
    opacity: 0.6;
  }
  .wr-arrow {
    font-size: var(--text-sm);
    color: var(--color-gold);
  }

  .footer-credit {
    font-size: var(--text-xs);
    color: var(--color-sage);
    font-style: italic;
    max-width: none;
    margin: 0;
    opacity: 0.6;
  }
</style>
