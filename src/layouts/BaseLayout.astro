          <!-- warm brown hair -->
          <linearGradient id="rgHair" x1="78" y1="720" x2="90" y2="793" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#8A5228"/>
            <stop offset="1" stop-color="#2E1008"/>
          </linearGradient>
          <!-- aged-parchment book pages -->
          <linearGradient id="rgPage" x1="61" y1="771" x2="83" y2="784" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#EDE0C8"/>
            <stop offset="1" stop-color="#D0BC96"/>
