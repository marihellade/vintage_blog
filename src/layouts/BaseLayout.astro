          <ellipse cx="61" cy="775" rx="2.2" ry="1.5" fill="#BA9870" opacity="0.85" transform="rotate(-10 61 775)"/>
          <ellipse cx="73" cy="776" rx="2.2" ry="1.5" fill="#BA9870" opacity="0.85" transform="rotate(12 73 776)"/>

          <!-- ── open book in lap — angled in profile ── -->
          <path d="M59 773 Q66 771 75 773 L74 784 Q66 786 60 784 Z"
                fill="#EDE0C8" opacity="0.93"/>
          <!-- spine -->
          <line x1="66" y1="772" x2="66" y2="785" stroke="#C8984E" stroke-width="0.7" opacity="0.6"/>
          <!-- left page lines (near side) -->
          <line x1="61" y1="775" x2="65" y2="774" stroke="#9A8570" stroke-width="0.35" opacity="0.55"/>
          <line x1="61" y1="777" x2="65" y2="776" stroke="#9A8570" stroke-width="0.35" opacity="0.5"/>
          <line x1="61" y1="779" x2="65" y2="778" stroke="#9A8570" stroke-width="0.35" opacity="0.45"/>
          <line x1="61" y1="781" x2="64" y2="780" stroke="#9A8570" stroke-width="0.35" opacity="0.4"/>
          <!-- right page lines (far side) -->
          <line x1="67" y1="774" x2="73" y2="775" stroke="#9A8570" stroke-width="0.35" opacity="0.55"/>
          <line x1="67" y1="776" x2="73" y2="777" stroke="#9A8570" stroke-width="0.35" opacity="0.5"/>
          <line x1="67" y1="778" x2="72" y2="779" stroke="#9A8570" stroke-width="0.35" opacity="0.45"/>
          <line x1="67" y1="780" x2="72" y2="781" stroke="#9A8570" stroke-width="0.35" opacity="0.4"/>
          <!-- book border -->
          <path d="M59 773 Q66 771 75 773 L74 784 Q66 786 60 784 Z"
                fill="none" stroke="#C8984E" stroke-width="0.5" opacity="0.42"/>
          <!-- warm page glow -->
          <ellipse cx="67" cy="778" rx="11" ry="6" fill="url(#bookGlow)"/>

          <!-- ── neck — profile, facing left ── -->
          <!-- neck is on the left side of head; slight profile angle -->
          <path d="M68 751 Q66 752 65 754 L66 758 Q68 758 70 757 L70 753 Z"
                fill="#C8A880" opacity="0.88"/>

          <!-- ── head — profile facing left ── -->
          <!-- base head shape — elongated slightly for profile -->
          <ellipse cx="71" cy="742" rx="7" ry="7.5" fill="#D0B08A"/>
          <!-- profile jaw/chin cutout illusion — flatten the left (facing) side -->
          <path d="M64 740 Q63 744 64 748 Q65 752 68 754 Q70 755 71 753"
                fill="#D0B08A" stroke="none"/>

          <!-- ── profile face features — facing left ── -->
          <!-- forehead curve -->
          <path d="M66 735 Q64 739 64 743" stroke="#BA9870" stroke-width="0.4" fill="none" opacity="0.3"/>
          <!-- eyebrow — single, arched, near side -->
          <path d="M65.5 739.5 Q68 738 70 739" stroke="#6B4030" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.7"/>
          <!-- eye — profile, single, downcast reading gaze -->
          <ellipse cx="67.5" cy="741.5" rx="2" ry="1.3" fill="#3A2010" opacity="0.85"/>
          <ellipse cx="67.2" cy="741.5" rx="0.7" ry="1.1" fill="#1A0E08"/>
          <!-- upper lash -->
          <path d="M65.5 740.5 Q67.5 739.5 69.5 740.5" stroke="#3A2010" stroke-width="0.65" stroke-linecap="round" fill="none" opacity="0.75"/>
          <!-- lower lash -->
          <path d="M65.8 742.5 Q67.5 743.2 69.2 742.5" stroke="#6B4030" stroke-width="0.35" stroke-linecap="round" fill="none" opacity="0.4"/>
          <!-- nose — side profile bump -->
          <path d="M64.5 744 Q63 746 63.5 748 Q64.5 750 66 750.5"
                stroke="#BA9870" stroke-width="0.9" stroke-linecap="round" fill="none" opacity="0.55"/>
          <!-- lips — profile, small and soft -->
          <path d="M64.8 751 Q65.8 752 66.8 751.5" stroke="#C49878" stroke-width="0.9" stroke-linecap="round" fill="none" opacity="0.55"/>
          <path d="M64.8 751 Q65.4 750.2 66.2 750.8" stroke="#C49878" stroke-width="0.7" stroke-linecap="round" fill="none" opacity="0.45"/>
          <!-- chin -->
          <path d="M66.8 751.5 Q67 753 68 754" stroke="#BA9870" stroke-width="0.5" fill="none" opacity="0.35"/>
          <!-- cheek blush — soft warm flush -->
          <ellipse cx="67" cy="746" rx="2.8" ry="1.8" fill="#D4853A" opacity="0.09"/>
          <!-- ear — far side, partially visible -->
          <ellipse cx="76" cy="743" rx="1.6" ry="2" fill="#BA9870" opacity="0.55"/>

          <!-- ── hair crown — profile, full side volume ── -->
          <!-- main hair mass (back of head to right) -->
          <ellipse cx="72" cy="739" rx="8.5" ry="5.5" fill="#5A3820"/>
          <!-- hair on top flowing back -->
          <path d="M67 734 Q72 732 78 734 Q82 737 80 741"
                fill="#5A3820" stroke="none"/>
          <!-- highlight along crown -->
          <path d="M67 734 Q72 732 78 735" stroke="#9A6840" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.4"/>
          <!-- hair near face — soft wisps framing profile -->
          <path d="M66 736 Q65 739 65.5 743" stroke="#7A4830" stroke-width="1.4" stroke-linecap="round" fill="none" opacity="0.55"/>
          <path d="M66.5 736 Q66 740 67 744" stroke="#9A6840" stroke-width="0.7" stroke-linecap="round" fill="none" opacity="0.3"/>

        </g>
      </svg>
    </div>

    <Header />

    <div class:list={['page-wrapper', { 'full-width': fullWidth }]}>
      {!fullWidth && (
        <Sidebar />
      )}

      <main id="main-content" tabindex="-1">
        <slot />
      </main>

      {!fullWidth && (
        <aside class="right-sidebar">
          <slot name="right-sidebar" />

          <!-- Season widget -->
          <div class="widget-box">
            <h4 class="widget-title"><SproutIcon class="icon-sm" /> This Season</h4>
            <p class="season-text">
              Autumn light through the window. Books piling up on the nightstand.
              The garden is going golden and the air smells like woodsmoke and old leaves.
            </p>
          </div>

          <!-- Tea time widget -->
          <div class="widget-box tea-widget">
            <div class="tea-row">
              <TeaIcon class="icon-lg" />
              <p class="tea-text">tea count today: <strong>3</strong></p>
            </div>
            <div class="mini-stars" aria-hidden="true">
              <StarIcon delay={1} />
              <StarIcon delay={2} />
              <StarIcon delay={3} />
            </div>
          </div>

          <!-- Site updates -->
          <div class="widget-box">
            <h4 class="widget-title"><span class="widget-icon" aria-hidden="true">❧</span> Site Updates</h4>
            <ul class="updates-list">
              <li><span class="update-date">Mar 2026</span> site launched!</li>
              <li><span class="update-date">Mar 2026</span> book diary & plant journal added</li>
              <li><span class="update-date">Mar 2026</span> recipe box opened</li>
            </ul>
          </div>

          <!-- Faux hit counter -->
          <div class="widget-box hit-counter-widget">
            <p class="hit-counter">
              <span class="hit-label">visitors</span>
              <span class="hit-digits">001,247</span>
            </p>
          </div>
        </aside>
      )}
    </div>

    <Footer />
  </body>
</html>

<style>
  .page-wrapper {
    display: grid;
    grid-template-columns: 210px 1fr 210px;
    gap: var(--space-6);
    max-width: var(--page-max);
    margin: 0 auto;
    padding: var(--space-6);
    align-items: start;
  }

  .page-wrapper.full-width {
    display: block;
    max-width: var(--content-max);
  }

  main {
    min-width: 0;
  }

  /* --- Right sidebar widget titles: match nav link readability --- */
  .right-sidebar .widget-title {
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-sm);
  }

  /* --- Right sidebar --- */
  .right-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .season-text {
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    line-height: 1.6;
    max-width: none;
    margin: 0;
  }

  .updates-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
  }
  .updates-list li {
    padding: var(--space-2) 0;
    border-bottom: 1px dotted var(--color-gold-light);
    color: var(--color-ink-soft);
    margin: 0;
  }
  .updates-list li:last-child { border-bottom: none; }
  .update-date {
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--color-terracotta);
    margin-right: var(--space-2);
  }

  /* --- Tea widget --- */
  .tea-widget { text-align: center; }
  .tea-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }
  .tea-text {
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    margin: 0;
    max-width: none;
  }
  .tea-text strong {
    color: var(--color-terracotta);
    font-size: var(--text-md);
  }
  .mini-stars {
    display: flex;
    justify-content: center;
    gap: var(--space-1);
    margin-top: var(--space-2);
  }

  /* --- Hit counter --- */
  .hit-counter-widget { text-align: center; }
  .hit-counter {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    margin: 0;
  }
  .hit-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0;
    text-transform: none;
    color: var(--color-gold);
  }
  .hit-digits {
    font-family: 'Courier New', monospace;
    font-size: var(--text-md);
    letter-spacing: 0.2em;
    color: var(--color-sage-dark);
    background: var(--color-parchment);
    border: 1px solid var(--color-gold-light);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
  }

  /* --- Decorative tree --- */
  .page-tree {
    position: fixed;
    left: 100px;
    top: 0;
    width: 80px;
    height: 100vh;
    pointer-events: none;
    z-index: 0;
    opacity: 0.55;
  }
  .page-tree svg {
    width: 150%;
    height: 100%;
    overflow: visible;
  }

  /* --- Evanescent drifting leaves --- */
  .leaf-drift {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-fill-mode: both;
  }

  /* Four distinct drift paths */
  @keyframes leaf-fall-left {
    0%   { opacity: 0;    transform: translate(0,   0)   rotate(-8deg); }
    18%  { opacity: 0.65; }
    82%  { opacity: 0.35; }
    100% { opacity: 0;    transform: translate(-14px, 28px) rotate(-62deg); }
  }
  @keyframes leaf-fall-right {
    0%   { opacity: 0;    transform: translate(0,  0)   rotate(8deg); }
    18%  { opacity: 0.6;  }
    82%  { opacity: 0.3;  }
    100% { opacity: 0;    transform: translate(12px, 25px) rotate(58deg); }
  }
  @keyframes leaf-fall-down {
    0%   { opacity: 0;    transform: translate(0,  0)   rotate(0deg); }
    20%  { opacity: 0.55; }
    80%  { opacity: 0.35; }
    100% { opacity: 0;    transform: translate(-4px, 30px) rotate(-28deg); }
  }
  @keyframes leaf-swirl {
    0%   { opacity: 0;    transform: translate(0,    0)   rotate(0deg)   scale(1); }
    25%  { opacity: 0.6;  transform: translate(-5px, 9px) rotate(-22deg) scale(1.08); }
    75%  { opacity: 0.3;  transform: translate(-9px, 20px) rotate(-42deg) scale(0.95); }
    100% { opacity: 0;    transform: translate(-13px, 32px) rotate(-66deg) scale(0.8); }
  }

  /* Staggered delays per leaf */
  .leaf-1  { animation-name: leaf-fall-left;  animation-duration: 6.0s; animation-delay: 0.0s; }
  .leaf-2  { animation-name: leaf-fall-right; animation-duration: 7.0s; animation-delay: 1.5s; }
  .leaf-3  { animation-name: leaf-fall-left;  animation-duration: 5.5s; animation-delay: 3.0s; }
  .leaf-4  { animation-name: leaf-fall-right; animation-duration: 6.5s; animation-delay: 0.8s; }
  .leaf-5  { animation-name: leaf-fall-down;  animation-duration: 5.0s; animation-delay: 2.2s; }
  .leaf-6  { animation-name: leaf-fall-right; animation-duration: 7.5s; animation-delay: 4.5s; }
  .leaf-7  { animation-name: leaf-fall-left;  animation-duration: 6.2s; animation-delay: 5.0s; }
  .leaf-8  { animation-name: leaf-swirl;      animation-duration: 8.0s; animation-delay: 1.0s; }
  .leaf-9  { animation-name: leaf-fall-down;  animation-duration: 6.0s; animation-delay: 3.5s; }
  .leaf-10 { animation-name: leaf-fall-left;  animation-duration: 5.8s; animation-delay: 6.2s; }

  @media (prefers-reduced-motion: reduce) {
    .leaf-drift { animation: none; opacity: 0; }
  }

  /* Hide on smaller screens where it would crowd the layout */
  @media (max-width: 1300px) {
    .page-tree { display: none; }
  }

  /* --- Responsive: stack on narrow screens --- */
  @media (max-width: 900px) {
    .page-wrapper {
      grid-template-columns: 1fr;
    }
    .right-sidebar {
      order: 3;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: var(--space-4);
    }
  }
</style>
