---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Cursor from '../components/Cursor.astro';
import Sidebar from '../components/Sidebar.astro';
import TeaIcon from '../components/icons/TeaIcon.astro';
import StarIcon from '../components/icons/StarIcon.astro';
import SproutIcon from '../components/icons/SproutIcon.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  fullWidth?: boolean;
}

const {
  title,
  description = "Marihella's personal corner of the internet — books, plants, travel, and recipes.",
  image,
  fullWidth = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title} | Marihella</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Marihella`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    {image && <meta property="og:image" content={image} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <Cursor />

    <!-- Decorative tree — left edge of page -->
    <div class="page-tree" aria-hidden="true">
      <svg viewBox="0 0 120 800" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMax meet">
        <!-- roots -->
        <path d="M60 800 Q50 780 35 770 Q25 760 20 745" stroke="#2C1810" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.5"/>
        <path d="M60 800 Q65 785 75 775 Q85 765 88 750" stroke="#2C1810" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.4"/>
        <path d="M60 800 Q55 790 45 788 Q35 786 28 780" stroke="#2C1810" stroke-width="1.2" stroke-linecap="round" fill="none" opacity="0.3"/>
        <!-- main trunk -->
        <path d="M60 800 Q58 720 55 650 Q52 580 58 510 Q62 450 55 390 Q50 340 58 280 Q63 230 55 180 Q50 140 58 100 Q62 70 58 40" stroke="#2C1810" stroke-width="5" stroke-linecap="round" fill="none"/>
        <!-- trunk texture lines -->
        <path d="M60 750 Q56 720 59 690" stroke="#4A3728" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.4"/>
        <path d="M58 640 Q62 610 57 580" stroke="#4A3728" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.4"/>
        <path d="M60 520 Q55 490 60 460" stroke="#4A3728" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.4"/>

        <!-- large branches -->
        <path d="M57 480 Q40 460 20 440 Q5 420 2 400" stroke="#2C1810" stroke-width="3" stroke-linecap="round" fill="none"/>
        <path d="M57 480 Q70 455 85 430 Q98 410 105 385" stroke="#2C1810" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        <path d="M56 360 Q35 340 15 310 Q5 290 2 270" stroke="#2C1810" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        <path d="M57 360 Q72 340 90 315 Q103 295 108 270" stroke="#2C1810" stroke-width="2" stroke-linecap="round" fill="none"/>
        <path d="M56 240 Q38 220 18 200 Q8 185 4 165" stroke="#2C1810" stroke-width="2" stroke-linecap="round" fill="none"/>
        <path d="M57 240 Q74 220 90 200 Q102 182 106 162" stroke="#2C1810" stroke-width="1.8" stroke-linecap="round" fill="none"/>
        <path d="M57 140 Q42 120 25 105 Q14 92 8 76" stroke="#2C1810" stroke-width="1.8" stroke-linecap="round" fill="none"/>
        <path d="M57 140 Q70 118 83 102 Q94 88 98 72" stroke="#2C1810" stroke-width="1.5" stroke-linecap="round" fill="none"/>

        <!-- smaller branches -->
        <path d="M20 440 Q10 430 2 418" stroke="#2C1810" stroke-width="1.2" stroke-linecap="round" fill="none" opacity="0.8"/>
        <path d="M20 440 Q15 424 12 410" stroke="#2C1810" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.7"/>
        <path d="M105 385 Q112 372 115 358" stroke="#2C1810" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.7"/>
        <path d="M15 310 Q6 298 2 283" stroke="#2C1810" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.7"/>
        <path d="M108 270 Q114 256 116 240" stroke="#2C1810" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.7"/>
        <path d="M18 200 Q8 188 3 173" stroke="#2C1810" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.7"/>
        <path d="M90 200 Q100 186 104 170" stroke="#2C1810" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.7"/>
        <path d="M25 105 Q18 92 14 78" stroke="#2C1810" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.7"/>
        <path d="M83 102 Q90 88 92 73" stroke="#2C1810" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.7"/>

        <!-- twigs -->
        <path d="M2 400 Q-2 390 0 378" stroke="#2C1810" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.5"/>
        <path d="M2 270 Q-1 258 1 246" stroke="#2C1810" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.5"/>
        <path d="M4 165 Q0 153 2 140" stroke="#2C1810" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.5"/>
        <path d="M8 76 Q4 64 6 52" stroke="#2C1810" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.5"/>
        <path d="M116 240 Q119 228 117 215" stroke="#2C1810" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.5"/>
        <path d="M58 40 Q52 24 55 8" stroke="#2C1810" stroke-width="1.5" stroke-linecap="round" fill="none"/>
        <path d="M58 40 Q66 25 62 10" stroke="#2C1810" stroke-width="1.2" stroke-linecap="round" fill="none" opacity="0.7"/>

        <!-- small leaves scattered on branches -->
        <ellipse cx="2" cy="395" rx="4" ry="2.5" fill="#4A7550" opacity="0.5" transform="rotate(-30 2 395)"/>
        <ellipse cx="108" cy="267" rx="4" ry="2.5" fill="#7A9E7E" opacity="0.5" transform="rotate(25 108 267)"/>
        <ellipse cx="4" cy="162" rx="3.5" ry="2" fill="#4A7550" opacity="0.45" transform="rotate(-20 4 162)"/>
        <ellipse cx="104" cy="168" rx="3.5" ry="2" fill="#7A9E7E" opacity="0.45" transform="rotate(15 104 168)"/>
        <ellipse cx="8" cy="73" rx="3" ry="1.8" fill="#4A7550" opacity="0.5" transform="rotate(-25 8 73)"/>
        <ellipse cx="93" cy="70" rx="3" ry="1.8" fill="#7A9E7E" opacity="0.5" transform="rotate(20 93 70)"/>
        <ellipse cx="55" cy="6" rx="3" ry="1.8" fill="#4A7550" opacity="0.5" transform="rotate(-10 55 6)"/>
        <ellipse cx="63" cy="8" rx="3" ry="1.8" fill="#7A9E7E" opacity="0.45" transform="rotate(30 63 8)"/>

        <!-- tiny dot leaves cluster near top -->
        <circle cx="50" cy="20" r="2" fill="#4A7550" opacity="0.4"/>
        <circle cx="65" cy="15" r="1.5" fill="#7A9E7E" opacity="0.4"/>
        <circle cx="45" cy="12" r="1.5" fill="#4A7550" opacity="0.35"/>
        <circle cx="70" cy="22" r="1.8" fill="#7A9E7E" opacity="0.35"/>
      </svg>
    </div>

    <Header />

    <div class:list={['page-wrapper', { 'full-width': fullWidth }]}>
      {!fullWidth && (
        <Sidebar />
      )}

      <main id="main-content" tabindex="-1">
        <slot />
      </main>

      {!fullWidth && (
        <aside class="right-sidebar">
          <slot name="right-sidebar" />

          <!-- Season widget -->
          <div class="widget-box">
            <h4 class="widget-title"><SproutIcon class="icon-sm" /> This Season</h4>
            <p class="season-text">
              Autumn light through the window. Books piling up on the nightstand.
              The garden is going golden and the air smells like woodsmoke and old leaves.
            </p>
          </div>

          <!-- Tea time widget -->
          <div class="widget-box tea-widget">
            <div class="tea-row">
              <TeaIcon class="icon-lg" />
              <p class="tea-text">tea count today: <strong>3</strong></p>
            </div>
            <div class="mini-stars" aria-hidden="true">
              <StarIcon delay={1} />
              <StarIcon delay={2} />
              <StarIcon delay={3} />
            </div>
          </div>

          <!-- Site updates -->
          <div class="widget-box">
            <h4 class="widget-title"><span class="widget-icon" aria-hidden="true">❧</span> Site Updates</h4>
            <ul class="updates-list">
              <li><span class="update-date">Mar 2026</span> site launched!</li>
              <li><span class="update-date">Mar 2026</span> book diary & plant journal added</li>
              <li><span class="update-date">Mar 2026</span> recipe box opened</li>
            </ul>
          </div>

          <!-- Faux hit counter -->
          <div class="widget-box hit-counter-widget">
            <p class="hit-counter">
              <span class="hit-label">visitors</span>
              <span class="hit-digits">001,247</span>
            </p>
          </div>
        </aside>
      )}
    </div>

    <Footer />
  </body>
</html>

<style>
  .page-wrapper {
    display: grid;
    grid-template-columns: 210px 1fr 210px;
    gap: var(--space-6);
    max-width: var(--page-max);
    margin: 0 auto;
    padding: var(--space-6);
    align-items: start;
  }

  .page-wrapper.full-width {
    display: block;
    max-width: var(--content-max);
  }

  main {
    min-width: 0;
  }

  /* --- Right sidebar --- */
  .right-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .season-text {
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    line-height: 1.6;
    max-width: none;
    margin: 0;
  }

  .updates-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
  }
  .updates-list li {
    padding: var(--space-2) 0;
    border-bottom: 1px dotted var(--color-gold-light);
    color: var(--color-ink-soft);
    margin: 0;
  }
  .updates-list li:last-child { border-bottom: none; }
  .update-date {
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--color-terracotta);
    margin-right: var(--space-2);
  }

  /* --- Tea widget --- */
  .tea-widget { text-align: center; }
  .tea-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }
  .tea-text {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    margin: 0;
    max-width: none;
  }
  .tea-text strong {
    color: var(--color-terracotta);
    font-size: var(--text-md);
  }
  .mini-stars {
    display: flex;
    justify-content: center;
    gap: var(--space-1);
    margin-top: var(--space-2);
  }

  /* --- Hit counter --- */
  .hit-counter-widget { text-align: center; }
  .hit-counter {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    margin: 0;
  }
  .hit-label {
    font-family: var(--font-accent);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
  }
  .hit-digits {
    font-family: 'Courier New', monospace;
    font-size: var(--text-md);
    letter-spacing: 0.2em;
    color: var(--color-sage-dark);
    background: var(--color-parchment);
    border: 1px solid var(--color-gold-light);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
  }

  /* --- Decorative tree --- */
  .page-tree {
    position: fixed;
    left: 0;
    top: 0;
    width: 80px;
    height: 100vh;
    pointer-events: none;
    z-index: 0;
    opacity: 0.45;
  }
  .page-tree svg {
    width: 100%;
    height: 100%;
  }

  /* Hide on smaller screens where it would crowd the layout */
  @media (max-width: 1300px) {
    .page-tree { display: none; }
  }

  /* --- Responsive: stack on narrow screens --- */
  @media (max-width: 900px) {
    .page-wrapper {
      grid-template-columns: 1fr;
    }
    .right-sidebar {
      order: 3;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: var(--space-4);
    }
  }
</style>
