---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Cursor from '../components/Cursor.astro';
import Sidebar from '../components/Sidebar.astro';
import TeaIcon from '../components/icons/TeaIcon.astro';
import StarIcon from '../components/icons/StarIcon.astro';
import SproutIcon from '../components/icons/SproutIcon.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  fullWidth?: boolean;
}

const {
  title,
  description = "Marihella's personal corner of the internet — books, plants, travel, and recipes.",
  image,
  fullWidth = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title} | Marihella</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Marihella`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    {image && <meta property="og:image" content={image} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <Cursor />

    <!-- Decorative tree — left edge of page -->
