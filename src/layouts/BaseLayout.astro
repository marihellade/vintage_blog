          <path d="M 100 779 Q 106 786  107 792" stroke="#1A3020" stroke-width="0.5" fill="none" opacity="0.22"/>
          <!-- gold hem — delicate art nouveau border line -->
          <path d="M 64 793 Q 86 796  108 791"
                stroke="#C8984E" stroke-width="0.65" fill="none" opacity="0.38"/>

          <!-- ── 3. BODICE — fitted, sits above the skirt ── -->
