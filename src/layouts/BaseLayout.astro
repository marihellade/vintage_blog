<style>
  .page-wrapper {
    display: grid;
    grid-template-columns: 210px 1fr 210px;
    gap: var(--space-6);
    max-width: var(--page-max);
    margin: 0 auto;
    padding: var(--space-6);
    align-items: start;
  }

  .page-wrapper.full-width {
    display: block;
    max-width: var(--content-max);
  }

  main {
    min-width: 0;
  }

  /* --- Right sidebar widget titles: match nav link readability --- */
  .right-sidebar .widget-title {
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-sm);
  }

  /* --- Right sidebar --- */
  .right-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .season-text {
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    line-height: 1.6;
    max-width: none;
    margin: 0;
  }

  .updates-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
  }
  .updates-list li {
    padding: var(--space-2) 0;
    border-bottom: 1px dotted var(--color-gold-light);
    color: var(--color-ink-soft);
    margin: 0;
  }
  .updates-list li:last-child { border-bottom: none; }
  .update-date {
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--color-terracotta);
    margin-right: var(--space-2);
  }

  /* --- Tea widget --- */
  .tea-widget { text-align: center; }
  .tea-row {
    display: flex;
    align-items: center;
