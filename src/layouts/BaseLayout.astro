        <!-- ═══ READING GIRL — art nouveau profile, right of tree, facing left ═══ -->
        <defs>
          <!-- warm parchment skin -->
          <linearGradient id="rgSkin" x1="70" y1="722" x2="80" y2="762" gradientUnits="userSpaceOnUse">
