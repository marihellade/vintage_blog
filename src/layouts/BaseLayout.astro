                   Q 74 752  81 754
                   Q 87 756  89 763
                   L 88 769
                   Q 78 772  67 771
                   L 65 763 Z"
                fill="#3A5E4A"/>
          <!-- shadow on facing side for form -->
          <path d="M 67 756 L 65 763 Q 66 769  68 771 Q 66 763  67 756"
                fill="#182C20" opacity="0.42"/>
          <!-- neckline — delicate arc -->
          <path d="M 69 754 Q 76 751  85 756"
                stroke="#5A8862" stroke-width="0.7" stroke-linecap="round" fill="none" opacity="0.52"/>
          <!-- shoulder caps -->
          <path d="M 67 757 Q 64 760  63 765" stroke="#2A4838" stroke-width="3"   stroke-linecap="round" fill="none" opacity="0.72"/>
          <path d="M 88 758 Q 90 761  90 767" stroke="#2A4838" stroke-width="3"   stroke-linecap="round" fill="none" opacity="0.65"/>

          <!-- ── 4. ARMS — reaching down and forward to hold the book ── -->
          <path d="M 67 762 Q 65 768  63 776"
                stroke="#C4A070" stroke-width="4" stroke-linecap="round" fill="none"/>
          <path d="M 87 764 Q 85 769  83 777"
                stroke="#C4A070" stroke-width="3.5" stroke-linecap="round" fill="none"/>
          <ellipse cx="63" cy="777" rx="2.6" ry="1.8" fill="#B8906A" transform="rotate(-14 63 777)"/>
          <ellipse cx="83" cy="778" rx="2.6" ry="1.8" fill="#B8906A" transform="rotate(9 83 778)"/>

          <!-- ── 5. OPEN BOOK IN LAP ── -->
          <path d="M 61 773 Q 72 771  84 773 L 83 785 Q 72 787  61 785 Z"
                fill="url(#rgPage)"/>
          <line x1="72" y1="771" x2="72" y2="786" stroke="#C8984E" stroke-width="0.9" opacity="0.55"/>
          <!-- left page lines -->
          <line x1="62" y1="775.0" x2="71" y2="774.5" stroke="#9A8870" stroke-width="0.35" opacity="0.52"/>
          <line x1="62" y1="777.0" x2="71" y2="776.5" stroke="#9A8870" stroke-width="0.35" opacity="0.50"/>
          <line x1="62" y1="779.0" x2="71" y2="778.5" stroke="#9A8870" stroke-width="0.35" opacity="0.45"/>
          <line x1="62" y1="781.0" x2="71" y2="780.5" stroke="#9A8870" stroke-width="0.35" opacity="0.40"/>
          <line x1="62" y1="783.0" x2="70" y2="782.5" stroke="#9A8870" stroke-width="0.35" opacity="0.35"/>
          <!-- right page lines -->
          <line x1="73" y1="774.5" x2="82" y2="775.0" stroke="#9A8870" stroke-width="0.35" opacity="0.52"/>
          <line x1="73" y1="776.5" x2="82" y2="777.0" stroke="#9A8870" stroke-width="0.35" opacity="0.50"/>
          <line x1="73" y1="778.5" x2="82" y2="779.0" stroke="#9A8870" stroke-width="0.35" opacity="0.45"/>
          <line x1="73" y1="780.5" x2="81" y2="781.0" stroke="#9A8870" stroke-width="0.35" opacity="0.40"/>
          <line x1="73" y1="782.5" x2="81" y2="783.0" stroke="#9A8870" stroke-width="0.35" opacity="0.35"/>
          <path d="M 61 773 Q 72 771  84 773 L 83 785 Q 72 787  61 785 Z"
                fill="none" stroke="#C8984E" stroke-width="0.65" opacity="0.42"/>
          <ellipse cx="72" cy="779" rx="14" ry="7" fill="url(#rgGlow)"/>

          <!-- ── 6. NECK ── -->
          <path d="M 73 747 Q 71 750  71 755 Q 71 759  74 760
                   Q 77 761  79 758 Q 80 754  79 749 Q 77 746  75 746 Z"
                fill="url(#rgSkin)"/>

          <!-- ── 7. HEAD — single profile silhouette path, facing left ──
               Traces: forehead → nose (furthest-left point) → lips → chin
               → jaw → skull-back → crown → back to hairline.
               The nose bump at x≈69.5 is what makes this read as a profile. -->
          <path d="M 76 724
                   Q 72 728  70 733
                   Q 69.5 737  69.5 740
                   Q 69.5 743  70 745
                   Q 70.5 747  71 749
                   Q 72 752  72.5 754
                   Q 73.5 757  75 758
                   Q 78 760  82 759
                   Q 88 757  91 749
                   Q 93 741  91 733
                   Q 89 726  84 722
                   Q 80 720  76 724 Z"
                fill="url(#rgSkin)"/>

          <!-- ── 8. FACE DETAILS ── -->

          <!-- eyebrow — elegant arched single stroke -->
          <path d="M 71.5 731.5 Q 74 729.5  77 731"
                stroke="#6A3C1C" stroke-width="0.95" stroke-linecap="round" fill="none" opacity="0.78"/>

          <!-- eye socket shadow — gives depth to the profile -->
          <ellipse cx="74" cy="734.5" rx="3.2" ry="2" fill="#6A3C1C" opacity="0.12"/>

          <!-- iris — profile shows a sliver, downcast (she is reading) -->
          <ellipse cx="72.5" cy="735" rx="1.6" ry="1.9" fill="#1E0E08" opacity="0.90"/>

          <!-- upper eyelid — clean art nouveau line -->
          <path d="M 70.5 733.5 Q 72.8 732  75.5 733.8"
                stroke="#2A1808" stroke-width="0.85" stroke-linecap="round" fill="none" opacity="0.82"/>
          <!-- lower lid -->
          <path d="M 70.8 736 Q 72.8 737  74.8 736.2"
                stroke="#7A4828" stroke-width="0.4" stroke-linecap="round" fill="none" opacity="0.42"/>

          <!-- nose — bridge indent then tip bump, key profile landmark -->
          <path d="M 70.5 737 Q 70 739.5  70.5 742"
                stroke="#C4A070" stroke-width="0.55" fill="none" opacity="0.38"/>
          <path d="M 70.5 742 Q 69.5 744.5  70 747"
                stroke="#B8906A" stroke-width="0.85" stroke-linecap="round" fill="none" opacity="0.58"/>
          <path d="M 70 747 Q 71 749  72.5 748.5"
                stroke="#A07850" stroke-width="0.65" stroke-linecap="round" fill="none" opacity="0.42"/>

          <!-- lips — art nouveau softness -->
          <path d="M 71.5 751 Q 73 749.5  74.5 750.5"
                stroke="#C49A78" stroke-width="1.0" stroke-linecap="round" fill="none" opacity="0.62"/>
          <path d="M 71.5 751 Q 73 753.5  74.5 752.5"
                stroke="#C49A78" stroke-width="1.2" stroke-linecap="round" fill="none" opacity="0.55"/>
          <path d="M 74.5 751.5 Q 75 752.2  74.5 752.8"
                stroke="#A07850" stroke-width="0.45" fill="none" opacity="0.38"/>

          <!-- chin -->
          <path d="M 74.5 753 Q 74.8 756  76 758"
                stroke="#C4A070" stroke-width="0.5" fill="none" opacity="0.28"/>

          <!-- cheek warmth — very faint, restraint per style guide -->
          <ellipse cx="75.5" cy="740.5" rx="4" ry="2.5" fill="#D4853A" opacity="0.07"/>

          <!-- ear — far side, partially visible -->
          <ellipse cx="84.5" cy="736.5" rx="1.8" ry="2.3" fill="#B8906A" opacity="0.52"/>
          <path d="M 84 735 Q 83.4 736.5  84 738"
                stroke="#9A7050" stroke-width="0.5" fill="none" opacity="0.28"/>

          <!-- ── 9. FRONT HAIR WISPS — drawn last, over the face ──
               Soft strands framing the forehead in the art nouveau manner.
               Layered opacity gives them depth without weight. -->
          <path d="M 79 722 Q 76 727  74.5 732 Q 73.5 736  73 740"
                stroke="#7A4820" stroke-width="1.8" stroke-linecap="round" fill="none" opacity="0.72"/>
          <path d="M 78 722 Q 75 728  73.5 734 Q 72.5 738  72.5 742"
                stroke="#5A3010" stroke-width="1.1" stroke-linecap="round" fill="none" opacity="0.52"/>
          <path d="M 80 723 Q 77.5 729  76 734 Q 75 738  74.5 742"
                stroke="#9A6030" stroke-width="0.7" stroke-linecap="round" fill="none" opacity="0.32"/>
          <path d="M 79 724 Q 77 730  76.5 736"
                stroke="#C09050" stroke-width="0.55" stroke-linecap="round" fill="none" opacity="0.22"/>

        </g>
      </svg>
    </div>

    <Header />

    <div class:list={['page-wrapper', { 'full-width': fullWidth }]}>
      {!fullWidth && (
        <Sidebar />
      )}

      <main id="main-content" tabindex="-1">
        <slot />
      </main>

      {!fullWidth && (
        <aside class="right-sidebar">
          <slot name="right-sidebar" />

          <!-- Season widget -->
          <div class="widget-box">
            <h4 class="widget-title"><SproutIcon class="icon-sm" /> This Season</h4>
            <p class="season-text">
              Autumn light through the window. Books piling up on the nightstand.
              The garden is going golden and the air smells like woodsmoke and old leaves.
            </p>
          </div>

          <!-- Tea time widget -->
          <div class="widget-box tea-widget">
            <div class="tea-row">
              <TeaIcon class="icon-lg" />
              <p class="tea-text">tea count today: <strong>3</strong></p>
            </div>
            <div class="mini-stars" aria-hidden="true">
              <StarIcon delay={1} />
              <StarIcon delay={2} />
              <StarIcon delay={3} />
            </div>
          </div>

          <!-- Site updates -->
          <div class="widget-box">
            <h4 class="widget-title"><span class="widget-icon" aria-hidden="true">❧</span> Site Updates</h4>
            <ul class="updates-list">
              <li><span class="update-date">Mar 2026</span> site launched!</li>
              <li><span class="update-date">Mar 2026</span> book diary & plant journal added</li>
              <li><span class="update-date">Mar 2026</span> recipe box opened</li>
            </ul>
          </div>

          <!-- Faux hit counter -->
          <div class="widget-box hit-counter-widget">
            <p class="hit-counter">
              <span class="hit-label">visitors</span>
              <span class="hit-digits">001,247</span>
            </p>
          </div>
        </aside>
      )}
    </div>

    <Footer />
  </body>
</html>

<style>
  .page-wrapper {
    display: grid;
    grid-template-columns: 210px 1fr 210px;
    gap: var(--space-6);
    max-width: var(--page-max);
    margin: 0 auto;
    padding: var(--space-6);
    align-items: start;
  }

  .page-wrapper.full-width {
    display: block;
    max-width: var(--content-max);
  }

  main {
    min-width: 0;
  }

  /* --- Right sidebar widget titles: match nav link readability --- */
  .right-sidebar .widget-title {
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-sm);
  }

  /* --- Right sidebar --- */
  .right-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .season-text {
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    line-height: 1.6;
    max-width: none;
    margin: 0;
  }

  .updates-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
  }
  .updates-list li {
    padding: var(--space-2) 0;
    border-bottom: 1px dotted var(--color-gold-light);
    color: var(--color-ink-soft);
    margin: 0;
  }
  .updates-list li:last-child { border-bottom: none; }
  .update-date {
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--color-terracotta);
    margin-right: var(--space-2);
  }

  /* --- Tea widget --- */
  .tea-widget { text-align: center; }
  .tea-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }
  .tea-text {
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    margin: 0;
    max-width: none;
  }
  .tea-text strong {
    color: var(--color-terracotta);
    font-size: var(--text-md);
  }
  .mini-stars {
    display: flex;
    justify-content: center;
    gap: var(--space-1);
    margin-top: var(--space-2);
  }

  /* --- Hit counter --- */
  .hit-counter-widget { text-align: center; }
  .hit-counter {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    margin: 0;
  }
  .hit-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0;
    text-transform: none;
    color: var(--color-gold);
  }
  .hit-digits {
    font-family: 'Courier New', monospace;
    font-size: var(--text-md);
    letter-spacing: 0.2em;
    color: var(--color-sage-dark);
    background: var(--color-parchment);
    border: 1px solid var(--color-gold-light);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
  }

  /* --- Decorative tree --- */
  .page-tree {
    position: fixed;
    left: 100px;
    top: 0;
    width: 80px;
    height: 100vh;
    pointer-events: none;
    z-index: 0;
    opacity: 0.55;
  }
  .page-tree svg {
    width: 150%;
    height: 100%;
    overflow: visible;
  }

  /* --- Evanescent drifting leaves --- */
  .leaf-drift {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-fill-mode: both;
  }

  /* Four distinct drift paths */
  @keyframes leaf-fall-left {
    0%   { opacity: 0;    transform: translate(0,   0)   rotate(-8deg); }
    18%  { opacity: 0.65; }
    82%  { opacity: 0.35; }
    100% { opacity: 0;    transform: translate(-14px, 28px) rotate(-62deg); }
  }
  @keyframes leaf-fall-right {
    0%   { opacity: 0;    transform: translate(0,  0)   rotate(8deg); }
    18%  { opacity: 0.6;  }
    82%  { opacity: 0.3;  }
    100% { opacity: 0;    transform: translate(12px, 25px) rotate(58deg); }
  }
  @keyframes leaf-fall-down {
    0%   { opacity: 0;    transform: translate(0,  0)   rotate(0deg); }
    20%  { opacity: 0.55; }
    80%  { opacity: 0.35; }
    100% { opacity: 0;    transform: translate(-4px, 30px) rotate(-28deg); }
  }
  @keyframes leaf-swirl {
    0%   { opacity: 0;    transform: translate(0,    0)   rotate(0deg)   scale(1); }
    25%  { opacity: 0.6;  transform: translate(-5px, 9px) rotate(-22deg) scale(1.08); }
    75%  { opacity: 0.3;  transform: translate(-9px, 20px) rotate(-42deg) scale(0.95); }
    100% { opacity: 0;    transform: translate(-13px, 32px) rotate(-66deg) scale(0.8); }
  }

  /* Staggered delays per leaf */
  .leaf-1  { animation-name: leaf-fall-left;  animation-duration: 6.0s; animation-delay: 0.0s; }
  .leaf-2  { animation-name: leaf-fall-right; animation-duration: 7.0s; animation-delay: 1.5s; }
  .leaf-3  { animation-name: leaf-fall-left;  animation-duration: 5.5s; animation-delay: 3.0s; }
  .leaf-4  { animation-name: leaf-fall-right; animation-duration: 6.5s; animation-delay: 0.8s; }
  .leaf-5  { animation-name: leaf-fall-down;  animation-duration: 5.0s; animation-delay: 2.2s; }
  .leaf-6  { animation-name: leaf-fall-right; animation-duration: 7.5s; animation-delay: 4.5s; }
  .leaf-7  { animation-name: leaf-fall-left;  animation-duration: 6.2s; animation-delay: 5.0s; }
  .leaf-8  { animation-name: leaf-swirl;      animation-duration: 8.0s; animation-delay: 1.0s; }
  .leaf-9  { animation-name: leaf-fall-down;  animation-duration: 6.0s; animation-delay: 3.5s; }
  .leaf-10 { animation-name: leaf-fall-left;  animation-duration: 5.8s; animation-delay: 6.2s; }

  @media (prefers-reduced-motion: reduce) {
    .leaf-drift { animation: none; opacity: 0; }
  }

  /* Hide on smaller screens where it would crowd the layout */
  @media (max-width: 1300px) {
    .page-tree { display: none; }
  }

  /* --- Responsive: stack on narrow screens --- */
  @media (max-width: 900px) {
    .page-wrapper {
      grid-template-columns: 1fr;
    }
    .right-sidebar {
      order: 3;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: var(--space-4);
    }
  }
</style>
