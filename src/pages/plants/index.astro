---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPlants  = await getCollection('plants');
const active     = allPlants.filter(p => p.data.status !== 'wishlist' && p.data.status !== 'rip');
const natives    = active.filter(p => p.data.category === 'native');
const vegetables = active.filter(p => p.data.category === 'vegetable');
const general    = active.filter(p => p.data.category !== 'native' && p.data.category !== 'vegetable');
const wishlist   = allPlants.filter(p => p.data.status === 'wishlist');
const rip        = allPlants.filter(p => p.data.status === 'rip');
const dramatic   = active.filter((plant) => ['recovering', 'dramatic', 'babying'].includes(plant.data.status));
---

<BaseLayout title="Plant Journal" description="Everything growing (or dramatically not growing) in Marihella's garden.">
  <div class="plant-page">

    <header class="page-header">
      <h1>Plant Journal</h1>
      <p class="page-intro">
        Everything growing in my garden I'll try include here — I am mostly growing Australian natives because the weather here likes to be dramatic and kill everything come summer. 
      </p>
    </header>

    <section class="garden-notes" aria-label="Garden notes">
      <article class="garden-note card">
        <p class="garden-note-label">Currently tending</p>
        <p class="garden-note-value">{active.length}</p>
        <p class="garden-note-copy">pots, beds, herbs, and whatever volunteered itself into a corner</p>
      </article>
      <article class="garden-note card">
        <p class="garden-note-label">Most dramatic patch</p>
        <p class="garden-note-value">{dramatic.length}</p>
        <p class="garden-note-copy">plants currently being coaxed, encouraged, or outright begged</p>
      </article>
      <article class="garden-note card">
        <p class="garden-note-label">Still dreaming of</p>
        <p class="garden-note-value">{wishlist.length}</p>
        <p class="garden-note-copy">future additions waiting for cooler weather and stronger self-control</p>
      </article>
    </section>

    <section class="plant-section">
      <h2 class="section-title">Natives I'm Growing</h2>
      <p class="section-note">The sturdy sun-lovers and soft silvery things I am trying to keep happy through Perth weather mood swings.</p>
      {natives.length > 0 ? (
        <div class="plant-grid">
          {natives.map(plant => (
            <div class="plant-card card">
              {plant.data.photo ? (
                <img src={plant.data.photo} alt={plant.data.name} class="plant-photo" loading="lazy" />
              ) : (
                <div class="plant-photo-placeholder">
                  <span aria-hidden="true">🌿</span>
                </div>
              )}
              <div class="plant-info">
                <h4>{plant.data.name}</h4>
                {plant.data.botanicalName && (
                  <p class="botanical"><em>{plant.data.botanicalName}</em></p>
                )}
                <span class={`status-pill ${plant.data.status}`}>{plant.data.status}</span>
                {plant.data.location && <p class="location">{plant.data.location}</p>}
                {plant.data.wateringNotes && <p class="care-note">{plant.data.wateringNotes}</p>}
                <div class="tag-row">
                  {plant.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p class="empty-section">No natives added yet — they're coming soon ✦</p>
      )}
    </section>

    <section class="plant-section">
      <h2 class="section-title">Vegetable Garden</h2>
      <p class="section-note">Seasonal optimism, dirt under the nails, and at least one patch that ends up far more chaotic than planned.</p>
      {vegetables.length > 0 ? (
        <div class="plant-grid">
          {vegetables.map(plant => (
            <div class="plant-card card">
              {plant.data.photo ? (
                <img src={plant.data.photo} alt={plant.data.name} class="plant-photo" loading="lazy" />
              ) : (
                <div class="plant-photo-placeholder vegetable">
                  <span aria-hidden="true">🥦</span>
                </div>
              )}
              <div class="plant-info">
                <h4>{plant.data.name}</h4>
                {plant.data.botanicalName && (
                  <p class="botanical"><em>{plant.data.botanicalName}</em></p>
                )}
                <span class={`status-pill ${plant.data.status}`}>{plant.data.status}</span>
                {plant.data.location && <p class="location">{plant.data.location}</p>}
                {plant.data.wateringNotes && <p class="care-note">{plant.data.wateringNotes}</p>}
                <div class="tag-row">
                  {plant.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p class="empty-section">Nothing planted yet — watch this space ✦</p>
      )}
    </section>

    {general.length > 0 && (
      <section class="plant-section">
        <h2 class="section-title">The Rest of the Garden</h2>
        <p class="section-note">Everything else that has found a home here, from dependable greenery to suspicious little experiments.</p>
        <div class="plant-grid">
          {general.map(plant => (
            <div class="plant-card card">
              {plant.data.photo ? (
                <img src={plant.data.photo} alt={plant.data.name} class="plant-photo" loading="lazy" />
              ) : (
                <div class="plant-photo-placeholder">
                  <span aria-hidden="true">🌿</span>
                </div>
              )}
              <div class="plant-info">
                <h4>{plant.data.name}</h4>
                {plant.data.botanicalName && (
                  <p class="botanical"><em>{plant.data.botanicalName}</em></p>
                )}
                <span class={`status-pill ${plant.data.status}`}>{plant.data.status}</span>
                {plant.data.location && <p class="location">{plant.data.location}</p>}
                {plant.data.wateringNotes && <p class="care-note">{plant.data.wateringNotes}</p>}
                <div class="tag-row">
                  {plant.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {wishlist.length > 0 && (
      <section class="plant-section">
        <h2 class="section-title">Wishlist</h2>
        <p class="section-note">The dangerous list of future companions I absolutely do not have room for yet.</p>
        <div class="plant-grid">
          {wishlist.map(plant => (
            <div class="plant-card card wishlist-card">
              <div class="plant-photo-placeholder wishlist">
                <span aria-hidden="true">✿</span>
              </div>
              <div class="plant-info">
                <h4>{plant.data.name}</h4>
                {plant.data.botanicalName && <p class="botanical"><em>{plant.data.botanicalName}</em></p>}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {rip.length > 0 && (
      <section class="plant-section">
        <h2 class="section-title">In Memoriam</h2>
        <p class="section-note">Gone, but not forgotten. Some plants simply arrive to teach a hard lesson and leave.</p>
        <div class="plant-grid">
          {rip.map(plant => (
            <div class="plant-card card rip-card">
              <div class="plant-info">
                <h4>{plant.data.name}</h4>
                <p class="botanical"><em>rest in peace</em></p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .plant-page {
    padding: var(--space-4) 0;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }
  .page-header h1 { color: var(--color-sage-dark); margin-bottom: var(--space-3); }
  .page-intro {
    max-width: 540px;
    margin: 0 auto;
    color: var(--color-ink-soft);
    font-style: italic;
  }

  .garden-notes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-10, 2.5rem);
  }

  .garden-note {
    position: relative;
    overflow: hidden;
  }

  .garden-note::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, rgba(154, 191, 158, 0.12), transparent 60%);
    pointer-events: none;
  }

  .garden-note-label,
  .garden-note-value,
  .garden-note-copy {
    position: relative;
    z-index: 1;
    max-width: none;
  }

  .garden-note-label {
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 var(--space-2);
  }

  .garden-note-value {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-style: italic;
    color: var(--color-sage-dark);
    margin: 0 0 var(--space-2);
  }

  .garden-note-copy {
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
    margin: 0;
  }

  .plant-section { margin-bottom: var(--space-12); }

  .section-note {
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
    font-style: italic;
    margin-bottom: var(--space-4);
    max-width: 62ch;
  }

  .empty-section {
    font-style: italic;
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
  }

  .plant-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
  }

  .plant-card {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    position: relative;
    overflow: hidden;
  }

  .plant-card::before {
    content: 'garden log';
    position: absolute;
    top: var(--space-3);
    right: var(--space-4);
    font-family: var(--font-accent);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(200, 152, 78, 0.45);
    pointer-events: none;
  }

  .plant-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at bottom right, rgba(122, 168, 126, 0.08), transparent 42%);
    pointer-events: none;
  }

  .plant-info,
  .plant-photo,
  .plant-photo-placeholder {
    position: relative;
    z-index: 1;
  }

  .plant-photo {
    width: 90px;
    height: 90px;
    object-fit: cover;
    border-radius: var(--radius-md);
    flex-shrink: 0;
    border: 1px solid rgba(237, 224, 200, 0.12);
  }

  .plant-photo-placeholder {
    width: 90px;
    height: 90px;
    flex-shrink: 0;
    background: linear-gradient(135deg, var(--color-sage-light), var(--color-sage));
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
  }
  .plant-photo-placeholder.wishlist {
    background: linear-gradient(135deg, var(--color-gold-light), var(--color-gold));
  }
  .plant-photo-placeholder.vegetable {
    background: var(--gradient-vegetable-cover);
  }

  .plant-info h4 { margin-bottom: var(--space-1); }

  .botanical {
    font-size: var(--text-xs);
    color: var(--color-ink-soft);
    margin-bottom: var(--space-2);
  }

  .status-pill {
    display: inline-block;
    font-family: var(--font-accent);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 1px var(--space-2);
    border-radius: 999px;
    margin-bottom: var(--space-2);
  }
  .status-pill.thriving  { background: var(--color-sage-light); color: var(--color-forest); }
  .status-pill.growing   { background: var(--color-status-growing); color: var(--color-sage-dark); }
  .status-pill.recovering { background: var(--color-status-recovering); color: var(--color-status-recovering-text); }
  .status-pill.dramatic  { background: var(--color-terracotta-light); color: var(--color-terracotta); }
  .status-pill.babying   { background: var(--color-status-babying); color: var(--color-status-babying-text); }

  .location {
    font-size: var(--text-xs);
    color: var(--color-ink-soft);
    margin-bottom: var(--space-1);
  }

  .care-note {
    font-size: var(--text-xs);
    font-style: italic;
    color: var(--color-sage-dark);
    margin-bottom: var(--space-2);
  }

  .tag-row { display: flex; flex-wrap: wrap; gap: var(--space-1); }

  .wishlist-card { opacity: 0.85; }
  .rip-card { opacity: 0.6; }

  @media (max-width: 720px) {
    .garden-notes {
      grid-template-columns: 1fr;
    }
  }
</style>
