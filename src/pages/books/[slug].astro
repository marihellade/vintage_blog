---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { starsHtml, starsLabel } from '../../utils/stars';
import { contentSlugFromId } from '../../utils/contentSlug';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map(book => ({
    params: { slug: contentSlugFromId(book.id) },
    props: { book },
  }));
}

interface Props { book: CollectionEntry<'books'>; }
const { book } = Astro.props;
const { Content } = await render(book);
const d = book.data;

const statusLabels: Record<string, string> = {
  'reading':      '📖~ reading ~',
  'finished':     '✨ finished ✨',
  'dnf':          '💔 dnf',
  'want-to-read': '👀 want 2 read',
};
---

<BaseLayout title={d.title} description={`${d.title} by ${d.author} — reviewed by Marihella`}>
  <article class="book-page">

    <header class="book-header">
      <div class="book-header-content">
        {d.cover ? (
          <img src={d.cover} alt={`Cover of ${d.title}`} class="cover-large" />
        ) : (
          <div class="cover-placeholder-large">
            <span>{d.title.charAt(0)}</span>
          </div>
        )}

        <div class="book-meta-block">
          <h1>{d.title}</h1>
          <p class="author">by {d.author}</p>

          {d.series && (
            <p class="series-info">{d.series}{d.seriesNumber ? ` #${d.seriesNumber}` : ''}</p>
          )}

          {d.rating && (
            <p class="rating" aria-label={starsLabel(d.rating)}>
              {starsHtml(d.rating)}
            </p>
          )}

          <div class="meta-details">
            {d.status && <span class={`status-badge ${d.status}`}>{statusLabels[d.status] ?? d.status}</span>}
            {d.dateStarted && (
              <span class="date-info">
                started {d.dateStarted.toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' })}
              </span>
            )}
            {d.dateFinished && (
              <span class="date-info">
                finished {d.dateFinished.toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' })}
              </span>
            )}
            {d.dateReread && (
              <span class="date-info reread">
                re-read {d.dateReread.toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' })}
              </span>
            )}
          </div>

          {d.mood && <p class="mood-display">{d.mood}</p>}

          {d.tags.length > 0 && (
            <div class="tag-row">
              {d.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}

          {d.format.length > 0 && (
            <div class="format-row">
              {d.format.map(f => <span class="format-badge">{f.replace('-', ' ')}</span>)}
            </div>
          )}
        </div>
      </div>
    </header>

    {d.favouriteQuote && (
      <div class="favourite-quote border-botanical">
        <h5>Favourite Quote</h5>
        <blockquote>&ldquo;{d.favouriteQuote}&rdquo;</blockquote>
      </div>
    )}

    <div class="book-sections">

      <section class="book-section-panel">
        <h2 class="panel-title">✎ Thoughts whilst reading</h2>
        {d.thoughts ? (
          <div class="panel-body thoughts-body">
            {d.thoughts.split('\n').filter((l: string) => l.trim()).map((para: string) => (
              <p>{para}</p>
            ))}
          </div>
        ) : (
          <p class="panel-empty">No reading notes yet.</p>
        )}
      </section>

      <section class="book-section-panel">
        <h2 class="panel-title">✦ Review</h2>
        <div class="panel-body review-body">
          <Content />
        </div>
      </section>

    </div>

    <footer class="book-footer">
      <a href="/books">&larr; back to the book diary</a>
    </footer>

  </article>
</BaseLayout>

<style>
  .book-page {
    padding: var(--space-4) 0;
  }

  .book-header {
    margin-bottom: var(--space-8);
  }

  .book-header-content {
    display: flex;
    gap: var(--space-8);
    align-items: flex-start;
  }

  .cover-large {
    width: 160px;
    height: 240px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-md);
    flex-shrink: 0;
  }

  .cover-placeholder-large {
    width: 160px;
    height: 240px;
    flex-shrink: 0;
    background: linear-gradient(135deg, var(--color-sage-light), var(--color-sage-dark));
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-style: italic;
    color: white;
    box-shadow: var(--shadow-md);
  }

  .book-meta-block h1 {
    font-size: var(--text-2xl);
    color: var(--color-ink);
    margin-bottom: var(--space-1);
  }

  .author {
    font-style: italic;
    color: var(--color-ink-soft);
    font-size: var(--text-md);
    margin-bottom: var(--space-2);
  }

  .series-info {
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-terracotta);
    margin-bottom: var(--space-2);
  }

  .rating {
    color: var(--color-gold);
    letter-spacing: 0.2em;
    font-size: var(--text-md);
    margin-bottom: var(--space-3);
  }

  .meta-details {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .status-badge {
    font-family: var(--font-accent);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px var(--space-3);
    border-radius: 999px;
  }
  .status-badge.reading { background: #3A1810; color: var(--color-terracotta); }
  .status-badge.finished { background: #1A301A; color: var(--color-sage-dark); }
  .status-badge.dnf { background: #2A1A06; color: #D4953A; }
  .status-badge.want-to-read { background: #2A1E08; color: var(--color-gold); }

  .date-info {
    font-size: var(--text-xs);
    color: var(--color-ink-soft);
    font-style: italic;
  }
  .date-info.reread {
    color: var(--color-gold);
  }

  .mood-display {
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-sage-dark);
    margin-bottom: var(--space-3);
    max-width: none;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .format-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .format-badge {
    font-family: var(--font-accent);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px var(--space-2);
    border-radius: 999px;
    background: #1A1A2E;
    color: #B8A9C9;
    border: 1px solid rgba(184, 169, 201, 0.25);
  }

  /* --- Quote --- */
  .favourite-quote {
    padding: var(--space-6);
    background: linear-gradient(160deg, #201A12 0%, #181310 100%);
    border: 1px solid var(--color-gold-light);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-8);
    text-align: center;
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.55);
  }
  .favourite-quote h5 {
    margin-bottom: var(--space-3);
    color: var(--color-gold);
  }
  .favourite-quote blockquote {
    border: none;
    padding: 0;
    margin: 0;
    background: none;
    font-size: var(--text-lg);
    font-family: var(--font-heading);
    color: var(--color-ink);
  }

  /* --- Book sections --- */
  .book-sections {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .book-section-panel {
    background: linear-gradient(160deg, #201A12 0%, #181310 100%);
    border: 1px solid var(--color-gold-light);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.55), inset 0 1px 0 rgba(200, 152, 78, 0.07);
    position: relative;
  }
  /* Inner dashed border — old letter / grimoire effect */
  .book-section-panel::before {
    content: '';
    position: absolute;
    inset: 4px;
    border: 1px dashed rgba(200, 152, 78, 0.15);
    border-radius: calc(var(--radius-md) - 4px);
    pointer-events: none;
  }

  .panel-title {
    font-family: var(--font-heading);
    font-size: var(--text-md);
    font-style: italic;
    font-weight: 400;
    color: var(--color-sage-dark);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px dotted var(--color-gold-light);
  }

  .panel-body :global(p) {
    margin-bottom: var(--space-4);
    color: var(--color-ink);
  }
  .panel-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .thoughts-body {
    font-style: italic;
    color: var(--color-ink-soft);
  }
  .thoughts-body p {
    color: var(--color-ink-soft);
  }

  .panel-empty {
    font-style: italic;
    color: var(--color-ink-soft);
    opacity: 0.5;
    font-size: var(--text-sm);
    margin: 0;
  }

  /* --- Footer --- */
  .book-footer {
    padding-top: var(--space-6);
    border-top: var(--border-thin);
  }
  .book-footer a {
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-sage-dark);
  }
  .book-footer a:hover { color: var(--color-terracotta); }

  @media (max-width: 600px) {
    .book-header-content { flex-direction: column; align-items: center; text-align: center; }
    .cover-large, .cover-placeholder-large { width: 120px; height: 180px; }
    .tag-row { justify-content: center; }
  }
</style>
