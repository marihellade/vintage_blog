---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookCard from '../../components/BookCard.astro';
import PageHeader from '../../components/PageHeader.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import { getCollection } from 'astro:content';
import { starsHtml, starsLabel } from '../../utils/stars';
import { bookCoverGradient } from '../../utils/bookColor';
import { contentSlugFromId } from '../../utils/contentSlug';

const allBooks = await getCollection('books');
const BOOKS_PER_PAGE = 6;
const UNDATED_YEAR = 'Undated';
const VISIBLE_REVIEWED_TAG_FILTERS = 6;
const ROMAN_NUMERALS = [
  ['M', 1000],
  ['CM', 900],
  ['D', 500],
  ['CD', 400],
  ['C', 100],
  ['XC', 90],
  ['L', 50],
  ['XL', 40],
  ['X', 10],
  ['IX', 9],
  ['V', 5],
  ['IV', 4],
  ['I', 1],
] as const;

const toRomanNumeral = (value: number) => {
  if (!Number.isFinite(value) || value <= 0) {
    return '—';
  }

  let remaining = Math.floor(value);
  let roman = '';

  for (const [symbol, amount] of ROMAN_NUMERALS) {
    while (remaining >= amount) {
      roman += symbol;
      remaining -= amount;
    }
  }

  return roman;
};

const formatRomanPageCount = (currentPage: number, totalPages: number) => totalPages > 0
  ? `${toRomanNumeral(currentPage)} / ${toRomanNumeral(totalPages)}`
  : '— / —';

const pageIntro = `Every book I've read, reviewed, and loved — or at least survived. I track my series,
my favourites, and the ones that made me sit in silence for ten minutes after finishing.`;

const compareByDateFinishedDesc = (a: typeof allBooks[number], b: typeof allBooks[number]) => {
  const aTime = a.data.dateFinished?.getTime();
  const bTime = b.data.dateFinished?.getTime();

  if (typeof aTime === 'number' && typeof bTime === 'number') {
    if (bTime !== aTime) {
      return bTime - aTime;
    }
  } else if (typeof aTime === 'number') {
    return -1;
  } else if (typeof bTime === 'number') {
    return 1;
  }

  return a.data.title.localeCompare(b.data.title);
};

// Status labels — MSN-era emoji vibe
const statusLabels: Record<string, string> = {
  'reading':      '📖~ reading ~',
  'finished':     '✨ finished ✨',
  'dnf':          '💔 dnf',
  'want-to-read': '👀 want 2 read',
};

// Group by status
const reading    = allBooks.filter(b => b.data.status === 'reading');
const finished   = allBooks
  .filter(book => book.data.status === 'finished')
  .sort(compareByDateFinishedDesc);
const dnf        = allBooks.filter(b => b.data.status === 'dnf');
const wantToRead = allBooks.filter(b => b.data.status === 'want-to-read');

type ReviewedBook = {
  slug: string;
  title: string;
  author: string;
  cover: string | null;
  rating: number | null;
  mood: string | null;
  tags: string[];
  year: number | 'Undated';
  dateFinished: string | null;
  coverGradient: string;
  ratingText: string | null;
  ratingLabel: string | null;
  finishedLabel: string;
};

const reviewedBooksData: ReviewedBook[] = finished.map((book) => ({
  slug: contentSlugFromId(book.id),
  title: book.data.title,
  author: book.data.author,
  cover: book.data.cover ?? null,
  rating: book.data.rating ?? null,
  mood: book.data.mood ?? null,
  tags: book.data.tags,
  year: book.data.dateFinished ? book.data.dateFinished.getFullYear() : UNDATED_YEAR,
  dateFinished: book.data.dateFinished?.toISOString() ?? null,
  coverGradient: bookCoverGradient(book.data.title),
  ratingText: book.data.rating ? starsHtml(book.data.rating) : null,
  ratingLabel: book.data.rating ? starsLabel(book.data.rating) : null,
  finishedLabel: book.data.dateFinished
    ? `finished ${book.data.dateFinished.getFullYear()}`
    : 'finished',
}));

const reviewedYearsNumeric = [...new Set(
  reviewedBooksData
    .map((book) => typeof book.year === 'number' ? book.year : null)
    .filter((year): year is number => year !== null),
)].sort((a, b) => b - a);

const reviewedYears: Array<number | 'Undated'> = [...reviewedYearsNumeric];

if (reviewedBooksData.some((book) => book.year === UNDATED_YEAR)) {
  reviewedYears.push(UNDATED_YEAR);
}

const reviewedBooksJson = JSON.stringify(reviewedBooksData).replace(/</g, '\\u003c');
// Keep the first shelf server-rendered for no-JS browsing and instant paint.
// The client script reuses the same data for sorting and pagination afterward.
const initialReviewedBooks = reviewedBooksData.slice(0, BOOKS_PER_PAGE);
const initialReviewedPageCount = Math.max(1, Math.ceil(reviewedBooksData.length / BOOKS_PER_PAGE));
const reviewedTags = [...new Set(reviewedBooksData.flatMap((book) => book.tags))].sort();

// Group by series
const seriesMap = new Map<string, typeof allBooks>();
for (const book of allBooks) {
  if (book.data.series) {
    const list = seriesMap.get(book.data.series) || [];
    list.push(book);
    seriesMap.set(book.data.series, list);
  }
}
// Sort series entries by seriesNumber
for (const [, books] of seriesMap) {
  books.sort((a, b) => (a.data.seriesNumber ?? 0) - (b.data.seriesNumber ?? 0));
}

const statsLine = `${finished.length} books reviewed · ${seriesMap.size} series in progress`;
const hasReading = reading.length > 0;
const hasSeries = seriesMap.size > 0;
const hasReviewed = finished.length > 0;
const hasDnf = dnf.length > 0;
const hasWantToRead = wantToRead.length > 0;
const showReadingDivider = hasReading && (hasReviewed || hasSeries || hasDnf || hasWantToRead);
const showReviewedDivider = hasReviewed && (hasSeries || hasDnf || hasWantToRead);
const showSeriesDivider = hasSeries && (hasDnf || hasWantToRead);
const showDnfDivider = hasDnf && hasWantToRead;
---

<BaseLayout title="Book Diary" description="Every book I've read, reviewed, and loved — or at least survived.">
  <div class="book-archive">

    <PageHeader title="Book Diary" intro={pageIntro} stats={statsLine} />

    <!-- Currently Reading -->
    {hasReading && (
      <section class="book-section">
        <h2 class="section-title">Currently Reading</h2>
        <div class="book-grid">
          {reading.map(book => (
            <BookCard
              title={book.data.title}
              author={book.data.author}
              cover={book.data.cover ?? null}
              coverGradient={bookCoverGradient(book.data.title)}
              slug={contentSlugFromId(book.id)}
              variant="reading"
              mood={book.data.mood ?? null}
              tags={book.data.tags}
              series={book.data.series}
              seriesNumber={book.data.seriesNumber}
            />
          ))}
        </div>
      </section>
    )}

    {showReadingDivider && (
      <SectionDivider variant="botanical" />
    )}

    <!-- Reviewed -->
    {hasReviewed && (
      <section class="book-section reviewed-section">
        <div class="reviewed-section-header">
          <div class="reviewed-heading-block">
            <h2 class="section-title">Reviewed</h2>
          </div>
        </div>

        <div class="reviewed-shelf-frame">
          <div class="reviewed-shelf-body">
            <div class="reviewed-controls" role="group" aria-label="Reviewed books controls">
              <div class="reviewed-controls-primary">
                <div class="reviewed-filter-block">
                  <span class="reviewed-filter-label">Year</span>
                  <div class="reviewed-year-pills" role="group" aria-label="Filter reviewed books by year">
                    <button type="button" class="reviewed-pill is-active" data-year-filter="all" aria-pressed="true">All</button>
                    {reviewedYears.map((year) => (
                      <button
                        type="button"
                        class="reviewed-pill"
                        data-year-filter={String(year)}
                        aria-pressed="false"
                      >
                        {year}
                      </button>
                    ))}
                  </div>
                </div>

                {reviewedTags.length > 0 && (
                  <div class="reviewed-filter-block">
                    <span class="reviewed-filter-label">Mood</span>
                    <div id="reviewed-tag-pills" class="reviewed-tag-pills" role="group" aria-label="Filter reviewed books by tag">
                      <button type="button" class="reviewed-pill reviewed-pill--tag is-active" data-tag-filter="all" aria-pressed="true">All moods</button>
                      {reviewedTags.map((tag, index) => (
                        <button
                          type="button"
                          class="reviewed-pill reviewed-pill--tag"
                          data-tag-filter={tag}
                          data-collapsible-filter={index >= VISIBLE_REVIEWED_TAG_FILTERS ? 'true' : undefined}
                          aria-pressed="false"
                          hidden={index >= VISIBLE_REVIEWED_TAG_FILTERS}
                        >
                          {tag}
                        </button>
                      ))}
                      {reviewedTags.length > VISIBLE_REVIEWED_TAG_FILTERS && (
                        <button
                          id="reviewed-filter-toggle"
                          type="button"
                          class="reviewed-pill reviewed-pill--more"
                          aria-expanded="false"
                          aria-controls="reviewed-tag-pills"
                        >
                          + more
                        </button>
                      )}
                    </div>
                  </div>
                )}

                <div class="reviewed-sort-group" role="group" aria-label="Sort reviewed books">
                  <span class="reviewed-sort-label">Sort</span>
                  <button type="button" class="reviewed-sort-option is-active" data-sort="date" aria-pressed="true">Latest first</button>
                  <button type="button" class="reviewed-sort-option" data-sort="rating" aria-pressed="false">Highest rated</button>
                </div>
              </div>
            </div>

            <div id="reviewed-browser" class="reviewed-browser">
              <button
                id="reviewed-prev-button"
                type="button"
                class="reviewed-side-nav reviewed-side-nav--prev"
                aria-label="Previous shelf page"
                aria-controls="reviewed-grid"
                disabled
                hidden={initialReviewedPageCount <= 1}
              >
                <span class="reviewed-side-nav-symbol" aria-hidden="true">‹</span>
                <span class="reviewed-side-nav-label">prev</span>
              </button>

              <div id="reviewed-grid" class="book-grid reviewed-grid">
                {initialReviewedBooks.map((book) => (
                  <BookCard
                    title={book.title}
                    author={book.author}
                    cover={book.cover}
                    coverGradient={book.coverGradient}
                    slug={book.slug}
                    variant="reviewed"
                    mood={book.mood}
                    rating={book.rating}
                    ratingText={book.ratingText}
                    ratingLabel={book.ratingLabel}
                    finishedLabel={book.finishedLabel}
                    tags={book.tags}
                  />
                ))}
              </div>

              <p id="reviewed-empty" class="reviewed-empty" hidden>No books tucked onto this shelf yet.</p>

              <button
                id="reviewed-next-button"
                type="button"
                class="reviewed-side-nav reviewed-side-nav--next"
                aria-label="Next shelf page"
                aria-controls="reviewed-grid"
                disabled={initialReviewedPageCount <= 1}
                hidden={initialReviewedPageCount <= 1}
              >
                <span class="reviewed-side-nav-label">next</span>
                <span class="reviewed-side-nav-symbol" aria-hidden="true">›</span>
              </button>
            </div>

            <div
              id="reviewed-pagination"
              class="reviewed-pagination"
              hidden={initialReviewedPageCount <= 1}
            >
              <p class="reviewed-page-indicator" aria-live="polite" aria-atomic="true">
                <span class="reviewed-page-indicator-label">page</span>
                <span id="reviewed-page-indicator-value" class="reviewed-page-indicator-value">
                  {formatRomanPageCount(1, initialReviewedPageCount)}
                </span>
              </p>
            </div>
          </div>
        </div>

        <script id="reviewed-books-data" type="application/json" is:inline set:html={reviewedBooksJson}></script>
        <script src="../../scripts/reviewed-shelf.ts"></script>
      </section>
    )}

    {showReviewedDivider && (
      <SectionDivider variant="simple" />
    )}

    <!-- Series I'm Following -->
    {hasSeries && (
      <section class="book-section">
        <h2 class="section-title">Series I'm Following</h2>
        <div class="series-grid">
          {[...seriesMap.entries()].map(([seriesName, books]) => (
            <div class="series-card card">
              <h4>{seriesName}</h4>
              <ul class="series-list">
                {books.map(book => (
                  <li>
                    <a href={`/books/${contentSlugFromId(book.id)}`}>
                      {book.data.seriesNumber && <span class="series-num">#{book.data.seriesNumber}</span>}
                      {book.data.title}
                    </a>
                    <span class={`status-badge ${book.data.status}`}>{statusLabels[book.data.status] ?? book.data.status}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>
    )}

    {showSeriesDivider && (
      <SectionDivider variant="dots" />
    )}

    <!-- DNF -->
    {hasDnf && (
      <section class="book-section">
        <h2 class="section-title">💔 DNF</h2>
        <div class="book-grid">
          {dnf.map(book => (
            <BookCard
              title={book.data.title}
              author={book.data.author}
              cover={book.data.cover ?? null}
              coverGradient={bookCoverGradient(book.data.title)}
              slug={contentSlugFromId(book.id)}
              variant="dnf"
              mood={book.data.mood ?? null}
            />
          ))}
        </div>
      </section>
    )}

    {showDnfDivider && <SectionDivider variant="simple" />}

    <!-- Want to Read -->
    {hasWantToRead && (
      <section class="book-section">
        <h2 class="section-title">Want to Read</h2>
        <div class="book-grid">
          {wantToRead.map(book => (
            <BookCard
              title={book.data.title}
              author={book.data.author}
              cover={book.data.cover ?? null}
              coverGradient={bookCoverGradient(book.data.title)}
              slug={contentSlugFromId(book.id)}
              variant="wishlist"
            />
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .book-archive {
    padding: var(--space-4) 0;
  }

  .book-section { margin-bottom: 0; }

  .book-section .section-title {
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-gold-light);
    margin-bottom: var(--space-4);
  }

  .reviewed-section {
    position: relative;
  }

  .reviewed-section-header {
    margin-bottom: var(--space-4);
  }

  .reviewed-heading-block .section-title {
    margin-bottom: 0;
  }

  .reviewed-shelf-frame {
    position: relative;
  }

  .reviewed-shelf-body {
    position: relative;
    padding: var(--space-6);
    border: 1px solid var(--color-gold-light);
    border-radius: var(--radius-md);
    background: var(--gradient-surface-warm);
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.55), inset 0 1px 0 rgba(200, 152, 78, 0.07);
    overflow: clip;
  }

  .reviewed-shelf-body::before {
    content: '';
    position: absolute;
    inset: 4px;
    border: 1px dashed rgba(200, 152, 78, 0.15);
    border-radius: calc(var(--radius-md) - 4px);
    pointer-events: none;
  }

  .reviewed-controls {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-4);
    border-bottom: 1px solid var(--color-gold-light);
    margin-bottom: var(--space-6);
  }

  .reviewed-controls-primary {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: var(--space-4);
  }

  .reviewed-year-pills,
  .reviewed-tag-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .reviewed-filter-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .reviewed-filter-label {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--color-ink-soft);
  }

  .reviewed-pill {
    appearance: none;
    border: 1px solid var(--color-sage);
    background: rgba(95, 128, 101, 0.14);
    color: rgba(154, 191, 158, 0.88);
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px var(--space-3);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .reviewed-pill:hover,
  .reviewed-pill:focus-visible {
    background: rgba(154, 191, 158, 0.18);
    border-color: var(--color-sage-dark);
    outline: none;
  }

  .reviewed-pill.is-active {
    background: rgba(154, 191, 158, 0.25);
    border-color: var(--color-sage-dark);
    color: var(--color-cream);
    box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.3);
  }

  .reviewed-year-pills .reviewed-pill.is-active {
    border-bottom: 2px solid var(--color-gold);
  }

  .reviewed-pill--tag {
    border-color: var(--color-terracotta);
  }

  .reviewed-pill--tag:hover,
  .reviewed-pill--tag:focus-visible,
  .reviewed-pill--tag.is-active {
    background: rgba(212, 133, 58, 0.15);
    border-color: var(--color-terracotta);
    color: var(--color-cream);
  }

  .reviewed-pill--tag.is-active {
    position: relative;
    padding-left: calc(var(--space-3) + 0.35rem);
  }

  .reviewed-pill--tag.is-active::before {
    content: '';
    position: absolute;
    left: 0.4rem;
    top: 20%;
    width: 2px;
    height: 60%;
    background: var(--color-gold);
    border-radius: 999px;
  }

  .reviewed-pill--more {
    border: none;
    background: none;
    color: var(--color-ink-soft);
    padding: 0;
    text-decoration: underline;
    text-decoration-color: var(--color-gold-light);
    text-underline-offset: 0.2em;
  }

  .reviewed-pill--more:hover,
  .reviewed-pill--more:focus-visible {
    color: var(--color-cream);
    outline: none;
  }

  .reviewed-pill--more.is-active {
    color: var(--color-gold);
  }

  .reviewed-sort-group {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
    margin-left: auto;
    color: var(--color-ink-soft);
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }

  .reviewed-sort-label {
    color: var(--color-ink-soft);
    margin-right: var(--space-2);
  }

  .reviewed-sort-option {
    appearance: none;
    border: none;
    border-bottom: 1px solid transparent;
    background: none;
    color: inherit;
    cursor: pointer;
    font: inherit;
    letter-spacing: inherit;
    padding: 0;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .reviewed-sort-option + .reviewed-sort-option::before {
    content: '·';
    color: var(--color-gold-light);
    margin: 0 var(--space-2);
  }

  .reviewed-sort-option:hover,
  .reviewed-sort-option:focus-visible {
    color: var(--color-cream);
    outline: none;
  }

  .reviewed-sort-option.is-active {
    color: var(--color-gold);
    border-bottom: 1px solid currentColor;
  }

  /* --- Book grid --- */
  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-6);
  }

  .reviewed-grid {
    position: relative;
    z-index: 1;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
    align-content: start;
    transform-origin: center top;
    transition: opacity 0.15s ease, transform 0.15s ease;
    will-change: opacity, transform;
  }

  @media (max-width: 1023px) {
    .reviewed-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .reviewed-grid--measure {
    position: absolute;
    inset: 0 auto auto 0;
    visibility: hidden;
    pointer-events: none;
    min-height: 0 !important;
    transform: none !important;
    transition: none !important;
  }

  .reviewed-grid.flipping-out {
    opacity: 0;
    transform: perspective(800px) rotateY(-8deg);
  }

  .reviewed-grid.flipping-in {
    opacity: 0;
    transform: perspective(800px) rotateY(8deg);
  }

  /* --- Series --- */
  .series-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
  }

  .series-card h4 {
    font-style: italic;
    color: var(--color-sage-dark);
    margin-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-gold-light);
    padding-bottom: var(--space-2);
  }

  .series-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .series-list li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-2) 0;
    border-bottom: 1px dotted var(--color-gold-light);
    font-size: var(--text-sm);
  }
  .series-list li:last-child { border-bottom: none; }
  .series-list a { text-decoration: none; font-family: var(--font-heading); font-size: var(--text-base); }
  .series-num {
    color: var(--color-gold);
    font-size: var(--text-xs);
    margin-right: var(--space-1);
  }

  .status-badge {
    font-family: var(--font-accent);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 1px var(--space-2);
    border-radius: 999px;
    white-space: nowrap;
  }
  .status-badge.reading {
    background: var(--color-badge-reading);
    color: var(--color-terracotta);
  }
  .status-badge.finished {
    background: var(--color-badge-finished);
    color: var(--color-sage-dark);
  }
  .status-badge.dnf {
    background: var(--color-badge-dnf);
    color: var(--color-badge-dnf-text);
  }
  .status-badge.want-to-read {
    background: var(--color-badge-want);
    color: var(--color-gold);
  }

  .reviewed-empty {
    position: relative;
    z-index: 1;
    margin: var(--space-4) 0 0;
    padding: var(--space-6);
    text-align: center;
    color: var(--color-ink-soft);
    font-style: italic;
    border: 1px dotted var(--color-gold-light);
    border-radius: var(--radius-md);
    background: rgba(26, 20, 16, 0.45);
  }

  .reviewed-browser {
    position: relative;
    padding-inline: 3rem;
    min-height: 0;
  }

  .reviewed-pagination {
    position: relative;
    z-index: 1;
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }

  .reviewed-side-nav {
    appearance: none;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    border: 1px solid var(--color-gold-light);
    border-radius: var(--radius-sm);
    background: rgba(28, 22, 16, 0.7);
    color: var(--color-ink-soft);
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
