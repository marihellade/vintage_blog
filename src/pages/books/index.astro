---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { starsHtml, starsLabel } from '../../utils/stars';
import { bookCoverGradient } from '../../utils/bookColor';
import { contentSlugFromId } from '../../utils/contentSlug';

const allBooks = await getCollection('books');
const BOOKS_PER_PAGE = 6;
const UNDATED_YEAR = 'Undated';
const ROMAN_NUMERALS = [
  ['M', 1000],
  ['CM', 900],
  ['D', 500],
  ['CD', 400],
  ['C', 100],
  ['XC', 90],
  ['L', 50],
  ['XL', 40],
  ['X', 10],
  ['IX', 9],
  ['V', 5],
  ['IV', 4],
  ['I', 1],
] as const;

const toRomanNumeral = (value: number) => {
  if (!Number.isFinite(value) || value <= 0) {
    return '—';
  }

  let remaining = Math.floor(value);
  let roman = '';

  for (const [symbol, amount] of ROMAN_NUMERALS) {
    while (remaining >= amount) {
      roman += symbol;
      remaining -= amount;
    }
  }

  return roman;
};

const formatRomanPageCount = (currentPage: number, totalPages: number) => totalPages > 0
  ? `${toRomanNumeral(currentPage)} / ${toRomanNumeral(totalPages)}`
  : '— / —';

const compareByDateFinishedDesc = (a: typeof allBooks[number], b: typeof allBooks[number]) => {
  const aTime = a.data.dateFinished?.getTime();
  const bTime = b.data.dateFinished?.getTime();

  if (typeof aTime === 'number' && typeof bTime === 'number') {
    if (bTime !== aTime) {
      return bTime - aTime;
    }
  } else if (typeof aTime === 'number') {
    return -1;
  } else if (typeof bTime === 'number') {
    return 1;
  }

  return a.data.title.localeCompare(b.data.title);
};

// Status labels — MSN-era emoji vibe
const statusLabels: Record<string, string> = {
  'reading':      '📖~ reading ~',
  'finished':     '✨ finished ✨',
  'dnf':          '💔 dnf',
  'want-to-read': '👀 want 2 read',
};

// Group by status
const reading    = allBooks.filter(b => b.data.status === 'reading');
const finished   = allBooks
  .filter(book => book.data.status === 'finished')
  .sort(compareByDateFinishedDesc);
const dnf        = allBooks.filter(b => b.data.status === 'dnf');
const wantToRead = allBooks.filter(b => b.data.status === 'want-to-read');

type ReviewedBook = {
  slug: string;
  title: string;
  author: string;
  cover: string | null;
  rating: number | null;
  mood: string | null;
  tags: string[];
  year: number | 'Undated';
  dateFinished: string | null;
  coverGradient: string;
  ratingText: string | null;
  ratingLabel: string | null;
  finishedLabel: string;
};

const reviewedBooksData: ReviewedBook[] = finished.map((book) => ({
  slug: contentSlugFromId(book.id),
  title: book.data.title,
  author: book.data.author,
  cover: book.data.cover ?? null,
  rating: book.data.rating ?? null,
  mood: book.data.mood ?? null,
  tags: book.data.tags,
  year: book.data.dateFinished ? book.data.dateFinished.getFullYear() : UNDATED_YEAR,
  dateFinished: book.data.dateFinished?.toISOString() ?? null,
  coverGradient: bookCoverGradient(book.data.title),
  ratingText: book.data.rating ? starsHtml(book.data.rating) : null,
  ratingLabel: book.data.rating ? starsLabel(book.data.rating) : null,
  finishedLabel: book.data.dateFinished
    ? `finished ${book.data.dateFinished.getFullYear()}`
    : 'finished',
}));

const reviewedYearsNumeric = [...new Set(
  reviewedBooksData
    .map((book) => typeof book.year === 'number' ? book.year : null)
    .filter((year): year is number => year !== null),
)].sort((a, b) => b - a);

const reviewedYears: Array<number | 'Undated'> = [...reviewedYearsNumeric];

if (reviewedBooksData.some((book) => book.year === UNDATED_YEAR)) {
  reviewedYears.push(UNDATED_YEAR);
}

const reviewedBooksJson = JSON.stringify(reviewedBooksData).replace(/</g, '\\u003c');
// Keep the first shelf server-rendered for no-JS browsing and instant paint.
// The client script reuses the same data for sorting and pagination afterward.
const initialReviewedBooks = reviewedBooksData.slice(0, BOOKS_PER_PAGE);
const initialReviewedPageCount = Math.max(1, Math.ceil(reviewedBooksData.length / BOOKS_PER_PAGE));
const reviewedTags = [...new Set(reviewedBooksData.flatMap((book) => book.tags))].sort();

// Group by series
const seriesMap = new Map<string, typeof allBooks>();
for (const book of allBooks) {
  if (book.data.series) {
    const list = seriesMap.get(book.data.series) || [];
    list.push(book);
    seriesMap.set(book.data.series, list);
  }
}
// Sort series entries by seriesNumber
for (const [, books] of seriesMap) {
  books.sort((a, b) => (a.data.seriesNumber ?? 0) - (b.data.seriesNumber ?? 0));
}

// All unique tags
const allTags = [...new Set(allBooks.flatMap(b => b.data.tags))].sort();
---

<BaseLayout title="Book Diary" description="Every book I've read, reviewed, and loved — or at least survived.">
  <div class="book-archive">

    <header class="page-header">
      <h1>Book Diary</h1>
      <p class="page-intro">
        Every book I've read, reviewed, and loved — or at least survived. I track my series,
        my favourites, and the ones that made me sit in silence for ten minutes after finishing.
      </p>
    </header>

    <!-- Currently reading -->
    {reading.length > 0 && (
      <section class="book-section">
        <h2 class="section-title">Currently Reading</h2>
        <div class="book-grid">
          {reading.map(book => (
            <a href={`/books/${contentSlugFromId(book.id)}`} class="book-card card">
              {book.data.cover ? (
                <img src={book.data.cover} alt={`Cover of ${book.data.title}`} class="book-cover" loading="lazy" />
              ) : (
                <div class="book-cover-placeholder" style={`background: ${bookCoverGradient(book.data.title)}`}>
                  <span>{book.data.title.charAt(0)}</span>
                </div>
              )}
              <div class="book-info">
                <h4>{book.data.title}</h4>
                <p class="meta">{book.data.author}</p>
                {book.data.series && (
                  <p class="series-label">{book.data.series} #{book.data.seriesNumber}</p>
                )}
                {book.data.mood && <p class="mood-line">{book.data.mood}</p>}
                <div class="tag-row">
                  {book.data.tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Series tracker -->
    {seriesMap.size > 0 && (
      <section class="book-section">
        <h2 class="section-title">Series I'm Following</h2>
        <div class="series-grid">
          {[...seriesMap.entries()].map(([seriesName, books]) => (
            <div class="series-card card">
              <h4>{seriesName}</h4>
              <ul class="series-list">
                {books.map(book => (
                  <li>
                    <a href={`/books/${contentSlugFromId(book.id)}`}>
                      {book.data.seriesNumber && <span class="series-num">#{book.data.seriesNumber}</span>}
                      {book.data.title}
                    </a>
                    <span class={`status-badge ${book.data.status}`}>{statusLabels[book.data.status] ?? book.data.status}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- All reviewed -->
    {finished.length > 0 && (
      <section class="book-section reviewed-section">
        <div class="reviewed-section-header">
          <div class="reviewed-heading-block">
            <h2 class="section-title">Reviewed</h2>
            <p class="reviewed-section-note">
              the shelf where wall-staring favourites, dragon-fuelled binges, and train-ride obsessions
              get their neat little catalogue cards.
            </p>
          </div>
          <p class="reviewed-page-indicator" aria-live="polite" aria-atomic="true">
            <span class="reviewed-page-indicator-label">folio</span>
            <span id="reviewed-page-indicator-value" class="reviewed-page-indicator-value">
              {formatRomanPageCount(1, initialReviewedPageCount)}
            </span>
          </p>
        </div>

        <div class="reviewed-shelf-frame">
          <button
            id="reviewed-prev-button"
            type="button"
            class="reviewed-side-nav reviewed-side-nav--prev"
            aria-label="Previous shelf page"
            aria-controls="reviewed-grid"
            disabled
          >
            <span class="reviewed-side-nav-symbol" aria-hidden="true">‹</span>
            <span class="reviewed-side-nav-label">prev</span>
          </button>

          <div class="reviewed-shelf-body">
            <div class="reviewed-controls" role="group" aria-label="Reviewed books controls">
              <div class="reviewed-controls-primary">
                <div class="reviewed-filter-block">
                  <span class="reviewed-filter-label">Year</span>
                  <div class="reviewed-year-pills" role="group" aria-label="Filter reviewed books by year">
                    <button type="button" class="reviewed-pill is-active" data-year-filter="all" aria-pressed="true">All</button>
                    {reviewedYears.map((year) => (
                      <button
                        type="button"
                        class="reviewed-pill"
                        data-year-filter={String(year)}
                        aria-pressed="false"
                      >
                        {year}
                      </button>
                    ))}
                  </div>
                </div>

                <div class="reviewed-sort-group" role="group" aria-label="Sort reviewed books">
                  <span class="reviewed-sort-label">Sort</span>
                  <button type="button" class="reviewed-sort-option is-active" data-sort="date" aria-pressed="true">Latest first</button>
                  <button type="button" class="reviewed-sort-option" data-sort="rating" aria-pressed="false">Highest rated</button>
                </div>

                {reviewedTags.length > 0 && (
                  <details id="reviewed-mood-disclosure" class="reviewed-secondary-filters">
                    <summary class="reviewed-reveal-button">
                      <span class="reviewed-reveal-symbol" aria-hidden="true">+</span>
                      <span class="reviewed-reveal-label">mood notes</span>
                      <span id="reviewed-active-mood" class="reviewed-reveal-active" hidden></span>
                    </summary>
                    <div class="reviewed-filter-block reviewed-filter-block--secondary">
                      <span class="reviewed-filter-label">Mood</span>
                      <div class="reviewed-tag-pills" role="group" aria-label="Filter reviewed books by tag">
                        <button type="button" class="reviewed-pill reviewed-pill--tag is-active" data-tag-filter="all" aria-pressed="true">All moods</button>
                        {reviewedTags.map((tag) => (
                          <button
                            type="button"
                            class="reviewed-pill reviewed-pill--tag"
                            data-tag-filter={tag}
                            aria-pressed="false"
                          >
                            {tag}
                          </button>
                        ))}
                      </div>
                    </div>
                  </details>
                )}
              </div>
            </div>

            <div id="reviewed-grid" class="book-grid reviewed-grid">
              {initialReviewedBooks.map((book) => (
                <a href={`/books/${book.slug}`} class="book-card card reviewed-card">
                  <div class="reviewed-card-figure">
                    {book.cover ? (
                      <img
                        src={book.cover}
                        alt={`Cover of ${book.title}`}
                        class="book-cover reviewed-book-cover"
                        loading="lazy"
                      />
                    ) : (
                      <div class="book-cover-placeholder reviewed-book-cover-placeholder" style={`background: ${book.coverGradient}`}>
                        <span>{book.title.charAt(0)}</span>
                      </div>
                    )}
                  </div>
                  <div class="book-info reviewed-card-copy">
                    <h3 class="reviewed-card-title">{book.title}</h3>
                    <p class="meta reviewed-card-author">by {book.author}</p>
                    <div class="reviewed-card-line">
                      {book.rating && (
                        <>
                          <span
                            class="reviewed-card-rating"
                            role="img"
                            aria-label={book.ratingLabel ?? starsLabel(book.rating)}
                          >
                            {book.ratingText ?? starsHtml(book.rating)}
                          </span>
                          <span class="reviewed-card-divider" aria-hidden="true">·</span>
                        </>
                      )}
                      <span class="reviewed-card-status">{book.finishedLabel}</span>
                    </div>
                    {book.mood && <p class="reviewed-card-note">{book.mood}</p>}
                    {book.tags.length > 0 && (
                      <div class="tag-row reviewed-tag-row">
                        {book.tags.slice(0, 2).map((tag) => <span class="tag">{tag}</span>)}
                      </div>
                    )}
                  </div>
                </a>
              ))}
            </div>

            <p id="reviewed-empty" class="reviewed-empty" hidden>No books tucked onto this shelf yet.</p>
          </div>

          <button
            id="reviewed-next-button"
            type="button"
            class="reviewed-side-nav reviewed-side-nav--next"
            aria-label="Next shelf page"
            aria-controls="reviewed-grid"
            disabled={initialReviewedPageCount <= 1}
          >
            <span class="reviewed-side-nav-symbol" aria-hidden="true">›</span>
            <span class="reviewed-side-nav-label">next</span>
          </button>
        </div>

        <script id="reviewed-books-data" type="application/json" is:inline set:html={reviewedBooksJson}></script>
        <script>
          type ReviewedBook = {
            slug: string;
            title: string;
            author: string;
            cover: string | null;
            rating: number | null;
            mood: string | null;
            tags: string[];
            year: number | 'Undated';
            dateFinished: string | null;
            coverGradient: string;
            ratingText: string | null;
            ratingLabel: string | null;
            finishedLabel: string;
          };

          const initReviewedBooks = () => {
            const dataElement = document.querySelector('#reviewed-books-data');
            const grid = document.querySelector('#reviewed-grid');
            const emptyState = document.querySelector('#reviewed-empty');
            const previousButton = document.querySelector('#reviewed-prev-button');
            const nextButton = document.querySelector('#reviewed-next-button');
            const pageIndicator = document.querySelector('#reviewed-page-indicator-value');
            const moodDisclosure = document.querySelector('#reviewed-mood-disclosure');
            const activeMoodBadge = document.querySelector('#reviewed-active-mood');
            const yearButtons = Array.from(document.querySelectorAll('.reviewed-year-pills [data-year-filter]'));
            const tagButtons = Array.from(document.querySelectorAll('.reviewed-tag-pills [data-tag-filter]'));
            const sortButtons = Array.from(document.querySelectorAll('.reviewed-sort-group [data-sort]'));

            if (
              !(dataElement instanceof HTMLScriptElement)
              || !(grid instanceof HTMLElement)
              || !(emptyState instanceof HTMLElement)
              || !(previousButton instanceof HTMLButtonElement)
              || !(nextButton instanceof HTMLButtonElement)
              || !(pageIndicator instanceof HTMLElement)
            ) {
              return;
            }

            const booksPerPage = 6;
            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

            let currentYear = 'all';
            let currentTag = 'all';
            let currentSort = 'date';
            let currentPage = 1;
            let renderVersion = 0;

            const books = JSON.parse(dataElement.textContent || '[]') as ReviewedBook[];

            const escapeHtml = (value: string | number | null | undefined) => String(value ?? '')
              .replaceAll('&', '&amp;')
              .replaceAll('<', '&lt;')
              .replaceAll('>', '&gt;')
              .replaceAll('"', '&quot;')
              .replaceAll("'", '&#39;');

            const starsForRating = (rating: number) => {
              const full = Math.floor(rating);
              const half = rating % 1 >= 0.5 ? 1 : 0;
              const empty = 5 - full - half;
              return '✦'.repeat(full) + (half ? '✩' : '') + '✧'.repeat(empty);
            };

            const compareByDate = (a: ReviewedBook, b: ReviewedBook) => {
              const aTime = a.dateFinished ? new Date(a.dateFinished).getTime() : null;
              const bTime = b.dateFinished ? new Date(b.dateFinished).getTime() : null;

              if (aTime !== null && bTime !== null) {
                if (bTime !== aTime) {
                  return bTime - aTime;
                }
              } else if (aTime !== null) {
                return -1;
              } else if (bTime !== null) {
                return 1;
              }

              return a.title.localeCompare(b.title);
            };

            const compareByRating = (a: ReviewedBook, b: ReviewedBook) => {
              const aRating = typeof a.rating === 'number' ? a.rating : Number.NEGATIVE_INFINITY;
              const bRating = typeof b.rating === 'number' ? b.rating : Number.NEGATIVE_INFINITY;

              if (bRating !== aRating) {
                return bRating - aRating;
              }

              return compareByDate(a, b);
            };

            const romanNumerals = [
              ['M', 1000],
              ['CM', 900],
              ['D', 500],
              ['CD', 400],
              ['C', 100],
              ['XC', 90],
              ['L', 50],
              ['XL', 40],
              ['X', 10],
              ['IX', 9],
              ['V', 5],
              ['IV', 4],
              ['I', 1],
            ] as const;

            const toRomanNumeral = (value: number) => {
              if (!Number.isFinite(value) || value <= 0) {
                return '—';
              }

              let remaining = Math.floor(value);
              let roman = '';

              for (const [symbol, amount] of romanNumerals) {
                while (remaining >= amount) {
                  roman += symbol;
                  remaining -= amount;
                }
              }

              return roman;
            };

            const formatRomanPageCount = (page: number, total: number) => total > 0
              ? `${toRomanNumeral(page)} / ${toRomanNumeral(total)}`
              : '— / —';

            const renderCard = (book: ReviewedBook) => {
              const firstLetter = escapeHtml((book.title || '').charAt(0) || '?');
              const coverMarkup = book.cover
                ? `<img src="${escapeHtml(book.cover)}" alt="Cover of ${escapeHtml(book.title)}" class="book-cover reviewed-book-cover" loading="lazy" />`
                : `<div class="book-cover-placeholder reviewed-book-cover-placeholder" style="background: ${escapeHtml(book.coverGradient)}"><span>${firstLetter}</span></div>`;
              const ratingMarkup = typeof book.rating === 'number'
                ? `<span class="reviewed-card-rating" role="img" aria-label="${escapeHtml(book.ratingLabel || `Rating: ${book.rating} out of 5`)}">${escapeHtml(book.ratingText || starsForRating(book.rating))}</span>`
                : '';
              const moodMarkup = book.mood
                ? `<p class="reviewed-card-note">${escapeHtml(book.mood)}</p>`
                : '';
              const tagMarkup = (book.tags || [])
                .slice(0, 2)
                .map((tag: string) => `<span class="tag">${escapeHtml(tag)}</span>`)
                .join('');
              const tagSection = tagMarkup
                ? `<div class="tag-row reviewed-tag-row">${tagMarkup}</div>`
                : '';
              const dividerMarkup = ratingMarkup
                ? '<span class="reviewed-card-divider" aria-hidden="true">·</span>'
                : '';

              return `
                <a href="/books/${escapeHtml(book.slug)}" class="book-card card reviewed-card">
                  <div class="reviewed-card-figure">
                    ${coverMarkup}
                  </div>
                  <div class="book-info reviewed-card-copy">
                    <h3 class="reviewed-card-title">${escapeHtml(book.title)}</h3>
                    <p class="meta reviewed-card-author">by ${escapeHtml(book.author)}</p>
                    <div class="reviewed-card-line">
                      ${ratingMarkup}
                      ${dividerMarkup}
                      <span class="reviewed-card-status">${escapeHtml(book.finishedLabel)}</span>
                    </div>
                    ${moodMarkup}
                    ${tagSection}
                  </div>
                </a>
              `;
            };

            const wait = (duration: number) => new Promise((resolve) => window.setTimeout(resolve, duration));
            const nextFrame = () => new Promise((resolve) => requestAnimationFrame(() => requestAnimationFrame(resolve)));

            const updateControls = () => {
              yearButtons.forEach((button) => {
                if (!(button instanceof HTMLButtonElement)) {
                  return;
                }

                const isActive = button.dataset.yearFilter === currentYear;
                button.classList.toggle('is-active', isActive);
                button.setAttribute('aria-pressed', String(isActive));
              });

              tagButtons.forEach((button) => {
                if (!(button instanceof HTMLButtonElement)) {
                  return;
                }

                const isActive = button.dataset.tagFilter === currentTag;
                button.classList.toggle('is-active', isActive);
                button.setAttribute('aria-pressed', String(isActive));
              });

              sortButtons.forEach((button) => {
                if (!(button instanceof HTMLButtonElement)) {
                  return;
                }

                const isActive = button.dataset.sort === currentSort;
                button.classList.toggle('is-active', isActive);
                button.setAttribute('aria-pressed', String(isActive));
              });

              if (activeMoodBadge instanceof HTMLElement) {
                const hasActiveMood = currentTag !== 'all';
                activeMoodBadge.hidden = !hasActiveMood;
                activeMoodBadge.textContent = hasActiveMood ? currentTag : '';
              }

              if (moodDisclosure instanceof HTMLDetailsElement) {
                moodDisclosure.classList.toggle('has-active-filter', currentTag !== 'all');
              }
            };

            const updateNavigation = (totalPages: number) => {
              pageIndicator.textContent = formatRomanPageCount(totalPages === 0 ? 0 : currentPage, totalPages);
              previousButton.disabled = totalPages === 0 || currentPage <= 1;
              nextButton.disabled = totalPages === 0 || currentPage >= totalPages;
            };

            const render = async ({ animate = false } = {}) => {
              renderVersion += 1;
              const version = renderVersion;

              const filteredBooks = currentYear === 'all'
                ? books
                : books.filter((book: ReviewedBook) => String(book.year) === currentYear);
              const tagFilteredBooks = currentTag === 'all'
                ? filteredBooks
                : filteredBooks.filter((book: ReviewedBook) => book.tags.includes(currentTag));
              const sortedBooks = [...tagFilteredBooks].sort(currentSort === 'rating' ? compareByRating : compareByDate);
              const totalPages = Math.max(1, Math.ceil(sortedBooks.length / booksPerPage));

              if (currentPage > totalPages) {
                currentPage = 1;
              }

              const startIndex = (currentPage - 1) * booksPerPage;
              const pageBooks = sortedBooks.slice(startIndex, startIndex + booksPerPage);
              const cardsMarkup = pageBooks.map(renderCard).join('');

              updateControls();
              updateNavigation(sortedBooks.length === 0 ? 0 : totalPages);
              emptyState.textContent = currentYear === 'all' && currentTag === 'all'
                ? 'No books tucked onto this shelf yet.'
                : 'No books match this shelf filter yet.';
              emptyState.hidden = sortedBooks.length !== 0;

              if (!animate || prefersReducedMotion) {
                grid.classList.remove('flipping-out', 'flipping-in');
                grid.innerHTML = cardsMarkup;
                return;
              }

              grid.classList.remove('flipping-in');
              grid.classList.add('flipping-out');
              await wait(150);

              if (version !== renderVersion) {
                return;
              }

              grid.innerHTML = cardsMarkup;
              grid.classList.remove('flipping-out');
              grid.classList.add('flipping-in');
              await nextFrame();

              if (version !== renderVersion) {
                return;
              }

              grid.classList.remove('flipping-in');
            };

            document.addEventListener('click', (event) => {
              const target = event.target instanceof Element ? event.target : null;
              const yearButton = target?.closest('[data-year-filter]');
              const tagButton = target?.closest('[data-tag-filter]');
              const sortButton = target?.closest('[data-sort]');
              const previousShelfButton = target?.closest('#reviewed-prev-button');
              const nextShelfButton = target?.closest('#reviewed-next-button');

              if (yearButton instanceof HTMLButtonElement) {
                const nextYear = yearButton.dataset.yearFilter;

                if (!nextYear || nextYear === currentYear) {
                  return;
                }

                currentYear = nextYear;
                currentPage = 1;
                void render({ animate: true });
                return;
              }

              if (tagButton instanceof HTMLButtonElement) {
                const nextTag = tagButton.dataset.tagFilter;

                if (!nextTag || nextTag === currentTag) {
                  return;
                }

                currentTag = nextTag;
                currentPage = 1;
                void render({ animate: true });
                return;
              }

              if (sortButton instanceof HTMLButtonElement) {
                const nextSort = sortButton.dataset.sort;

                if (!nextSort || nextSort === currentSort) {
                  return;
                }

                currentSort = nextSort;
                currentPage = 1;
                void render({ animate: true });
                return;
              }

              if (previousShelfButton instanceof HTMLButtonElement && !previousShelfButton.disabled) {
                const nextPage = currentPage - 1;

                if (nextPage < 1) {
                  return;
                }

                currentPage = nextPage;
                void render({ animate: true });
                return;
              }

              if (nextShelfButton instanceof HTMLButtonElement && !nextShelfButton.disabled) {
                const nextPage = currentPage + 1;

                currentPage = nextPage;
                void render({ animate: true });
              }
            });

            void render();
          };

          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initReviewedBooks, { once: true });
          } else {
            initReviewedBooks();
          }
        </script>
      </section>
    )}

    <!-- DNF -->
    {dnf.length > 0 && (
      <section class="book-section">
        <h2 class="section-title">💔 DNF</h2>
        <div class="book-grid">
          {dnf.map(book => (
            <a href={`/books/${contentSlugFromId(book.id)}`} class="book-card card dnf-card">
              {book.data.cover ? (
                <img src={book.data.cover} alt={`Cover of ${book.data.title}`} class="book-cover" loading="lazy" />
              ) : (
                <div class="book-cover-placeholder dnf" style={`background: ${bookCoverGradient(book.data.title)}`}>
                  <span>{book.data.title.charAt(0)}</span>
                </div>
              )}
              <div class="book-info">
                <h4>{book.data.title}</h4>
                <p class="meta">{book.data.author}</p>
                {book.data.mood && <p class="mood-line">{book.data.mood}</p>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Want to read -->
    {wantToRead.length > 0 && (
      <section class="book-section">
        <h2 class="section-title">Want to Read</h2>
        <div class="book-grid">
          {wantToRead.map(book => (
            <a href={`/books/${contentSlugFromId(book.id)}`} class="book-card card">
              <div class="book-cover-placeholder wishlist" style={`background: ${bookCoverGradient(book.data.title)}`}>
                <span>{book.data.title.charAt(0)}</span>
              </div>
              <div class="book-info">
                <h4>{book.data.title}</h4>
                <p class="meta">{book.data.author}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Tags -->
    {allTags.length > 0 && (
      <section class="book-section tags-section">
        <h2 class="section-title">Browse by mood</h2>
        <div class="tag-row">
          {allTags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

