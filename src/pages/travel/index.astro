---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { contentSlugFromId } from '../../utils/contentSlug';

const allTravel = await getCollection('travel');
const sorted = allTravel.sort((a, b) => {
  const da = a.data.date?.getTime() ?? 0;
  const db = b.data.date?.getTime() ?? 0;
  return db - da;
});
const latestTrip = sorted[0];
---

<BaseLayout title="Travel" description="Places Marihella has wandered and wants to remember.">
  <div class="travel-page">

    <header class="page-header">
      <h1>Wanderings</h1>
      <p class="page-intro">
        Places I've been, things I've seen, and small moments I don't want to forget.
        Part vision board, part scrapbook.
      </p>
    </header>

    <section class="travel-stats" aria-label="Travel notes">
      <article class="travel-stat card">
        <p class="travel-stat-label">Trips logged</p>
        <p class="travel-stat-value">{sorted.length}</p>
        <p class="travel-stat-copy">little archives of walks, views, and places worth remembering</p>
      </article>
      <article class="travel-stat card">
        <p class="travel-stat-label">Latest stop</p>
        <p class="travel-stat-value">{latestTrip?.data.destination ?? 'Soon'}</p>
        <p class="travel-stat-copy">the most recent page tucked into the scrapbook</p>
      </article>
      <article class="travel-stat card">
        <p class="travel-stat-label">Always chasing</p>
        <p class="travel-stat-value">cafes + mist</p>
        <p class="travel-stat-copy">quiet corners, old streets, and weather that makes everything cinematic</p>
      </article>
    </section>

    <div class="travel-feed">
      {sorted.map((trip) => (
        <article class="travel-card card">
          <div class="travel-card-layout">
            {trip.data.cover ? (
              <img src={trip.data.cover} alt={`Photo from ${trip.data.title}`} class="travel-thumb" loading="lazy" />
            ) : (
              <div class="travel-thumb-placeholder">
                <span>{trip.data.destination.charAt(0)}</span>
              </div>
            )}

            <div class="travel-content">
              <div class="travel-heading">
                <h2>
                  <a href={`/travel/${contentSlugFromId(trip.id)}`}>{trip.data.title}</a>
                </h2>
                <div class="travel-meta">
                  <span class="destination">{trip.data.destination}</span>
                  {trip.data.date && (
                    <span class="travel-date">
                      {trip.data.date.toLocaleDateString('en-AU', { month: 'long', year: 'numeric' })}
                    </span>
                  )}
                </div>
              </div>

              {trip.data.mood && <p class="mood-line">{trip.data.mood}</p>}

              {trip.data.highlights.length > 0 && (
                <ul class="highlight-list">
                  {trip.data.highlights.slice(0, 2).map((highlight) => <li>{highlight}</li>)}
                </ul>
              )}

              {trip.data.tags.length > 0 && (
                <div class="tag-row">
                  {trip.data.tags.map((tag) => <span class="tag">{tag}</span>)}
                </div>
              )}

              <p class="travel-link">
                <a href={`/travel/${contentSlugFromId(trip.id)}`}>read the full entry &rarr;</a>
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .travel-page {
    padding: var(--space-4) 0;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }
  .page-header h1 { color: var(--color-sage-dark); margin-bottom: var(--space-3); }
  .page-intro {
    max-width: 500px;
    margin: 0 auto;
    color: var(--color-ink-soft);
    font-style: italic;
  }

  .travel-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-10, 2.5rem);
  }

  .travel-stat {
    position: relative;
    overflow: hidden;
  }

  .travel-stat::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top left, rgba(200, 152, 78, 0.1), transparent 60%);
    pointer-events: none;
  }

  .travel-stat-label,
  .travel-stat-value,
  .travel-stat-copy {
    position: relative;
    z-index: 1;
    max-width: none;
  }

  .travel-stat-label {
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 var(--space-2);
  }

  .travel-stat-value {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-style: italic;
    color: var(--color-sage-dark);
    margin: 0 0 var(--space-2);
    max-width: none;
  }

  .travel-stat-copy {
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
    margin: 0;
  }

  .travel-feed {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .travel-card {
    position: relative;
    overflow: hidden;
  }

  .travel-card:nth-child(odd) {
    transform: rotate(-0.35deg);
  }

  .travel-card:nth-child(even) {
    transform: rotate(0.35deg);
  }

  .travel-card:hover {
    transform: translateY(-3px) rotate(0deg);
  }

  .travel-card::before {
    content: 'postcard note';
    position: absolute;
    top: var(--space-3);
    right: var(--space-4);
    font-family: var(--font-accent);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(200, 152, 78, 0.45);
    pointer-events: none;
  }

  .travel-card::after {
    content: '';
    position: absolute;
    top: -10px;
    left: 32px;
    width: 72px;
    height: 20px;
    background: linear-gradient(180deg, rgba(237, 224, 200, 0.32), rgba(237, 224, 200, 0.06));
    border: 1px solid rgba(237, 224, 200, 0.16);
    border-radius: 3px;
    transform: rotate(-5deg);
    opacity: 0.7;
    pointer-events: none;
  }

  .travel-card-layout {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .travel-thumb,
  .travel-thumb-placeholder {
    width: 150px;
    height: 200px;
    object-fit: cover;
    border-radius: var(--radius-md);
    flex-shrink: 0;
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(237, 224, 200, 0.12);
  }

  .travel-thumb-placeholder {
    background: linear-gradient(135deg, var(--color-sage-light), var(--color-sage));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-style: italic;
    color: var(--color-cream);
  }

  .travel-heading {
    margin-bottom: var(--space-3);
  }

  .travel-content h2 {
    color: var(--color-ink);
    margin-bottom: var(--space-2);
  }

  .travel-content h2 a {
    color: inherit;
    text-decoration: none;
  }

  .travel-content h2 a:hover {
    color: var(--color-terracotta);
  }

  .travel-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
    flex-wrap: wrap;
  }

  .destination {
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-terracotta);
  }

  .travel-date {
    font-size: var(--text-xs);
    color: var(--color-ink-soft);
    font-style: italic;
  }

  .mood-line {
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-sage-dark);
    margin-bottom: var(--space-3);
  }

  .highlight-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-4);
  }
  .highlight-list li {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    padding-left: var(--space-4);
    position: relative;
    margin-bottom: var(--space-1);
  }
  .highlight-list li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--color-gold);
    font-size: var(--text-xs);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .travel-link {
    margin: var(--space-4) 0 0;
    max-width: none;
  }

  .travel-link a {
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  @media (max-width: 700px) {
    .travel-stats {
      grid-template-columns: 1fr;
    }

    .travel-card:nth-child(odd),
    .travel-card:nth-child(even) {
      transform: none;
    }

    .travel-card-layout {
      flex-direction: column;
    }

    .travel-thumb,
    .travel-thumb-placeholder {
      width: 100%;
      max-width: 320px;
      height: 220px;
    }
  }
</style>
