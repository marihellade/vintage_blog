---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allTravel = await getCollection('travel');
const sorted = allTravel.sort((a, b) => {
  const da = a.data.date?.getTime() ?? 0;
  const db = b.data.date?.getTime() ?? 0;
  return db - da;
});
---

<BaseLayout title="Travel" description="Places Marihella has wandered and wants to remember.">
  <div class="travel-page">

    <header class="page-header">
      <h1>Wanderings</h1>
      <p class="page-intro">
        Places I've been, things I've seen, and small moments I don't want to forget.
        Part vision board, part scrapbook.
      </p>
    </header>

    <div class="travel-feed">
      {sorted.map((trip) => (
        <article class="travel-card card">
          <div class="travel-card-layout">
            {trip.data.cover ? (
              <img src={trip.data.cover} alt={`Photo from ${trip.data.title}`} class="travel-thumb" loading="lazy" />
            ) : (
              <div class="travel-thumb-placeholder">
                <span>{trip.data.destination.charAt(0)}</span>
              </div>
            )}

            <div class="travel-content">
              <div class="travel-heading">
                <h2>
                  <a href={`/travel/${trip.slug}`}>{trip.data.title}</a>
                </h2>
                <div class="travel-meta">
                  <span class="destination">{trip.data.destination}</span>
                  {trip.data.date && (
                    <span class="travel-date">
                      {trip.data.date.toLocaleDateString('en-AU', { month: 'long', year: 'numeric' })}
                    </span>
                  )}
                </div>
              </div>

              {trip.data.mood && <p class="mood-line">{trip.data.mood}</p>}

              {trip.data.highlights.length > 0 && (
                <ul class="highlight-list">
                  {trip.data.highlights.slice(0, 2).map((highlight) => <li>{highlight}</li>)}
                </ul>
              )}

              {trip.data.tags.length > 0 && (
                <div class="tag-row">
                  {trip.data.tags.map((tag) => <span class="tag">{tag}</span>)}
                </div>
              )}

              <p class="travel-link">
                <a href={`/travel/${trip.slug}`}>read the full entry &rarr;</a>
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .travel-page {
    padding: var(--space-4) 0;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }
  .page-header h1 { color: var(--color-sage-dark); margin-bottom: var(--space-3); }
  .page-intro {
    max-width: 500px;
    margin: 0 auto;
    color: var(--color-ink-soft);
    font-style: italic;
  }

  .travel-feed {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .travel-card-layout {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .travel-thumb,
  .travel-thumb-placeholder {
    width: 150px;
    height: 200px;
    object-fit: cover;
    border-radius: var(--radius-md);
    flex-shrink: 0;
    box-shadow: var(--shadow-sm);
  }

  .travel-thumb-placeholder {
    background: linear-gradient(135deg, var(--color-sage-light), var(--color-sage));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-style: italic;
    color: var(--color-cream);
  }

  .travel-heading {
    margin-bottom: var(--space-3);
  }

  .travel-content h2 {
    color: var(--color-ink);
    margin-bottom: var(--space-2);
  }

  .travel-content h2 a {
    color: inherit;
    text-decoration: none;
  }

  .travel-content h2 a:hover {
    color: var(--color-terracotta);
  }

  .travel-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
    flex-wrap: wrap;
  }

  .destination {
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-terracotta);
  }

  .travel-date {
    font-size: var(--text-xs);
    color: var(--color-ink-soft);
    font-style: italic;
  }

  .mood-line {
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-sage-dark);
    margin-bottom: var(--space-3);
  }

  .highlight-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-4);
  }
  .highlight-list li {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    padding-left: var(--space-4);
    position: relative;
    margin-bottom: var(--space-1);
  }
  .highlight-list li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--color-gold);
    font-size: var(--text-xs);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .travel-link {
    margin: var(--space-4) 0 0;
    max-width: none;
  }

  .travel-link a {
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  @media (max-width: 700px) {
    .travel-card-layout {
      flex-direction: column;
    }

    .travel-thumb,
    .travel-thumb-placeholder {
      width: 100%;
      max-width: 320px;
      height: 220px;
    }
  }
</style>
