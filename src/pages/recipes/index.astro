---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { starsHtml, starsLabel } from '../../utils/stars';
import { contentSlugFromId } from '../../utils/contentSlug';

const allRecipes = await getCollection('recipes');
const sorted = allRecipes.sort((a, b) => {
  const da = a.data.dateTried?.getTime() ?? 0;
  const db = b.data.dateTried?.getTime() ?? 0;
  return db - da;
});
---

<BaseLayout title="Recipe Box" description="Recipes Marihella has tried, loved, and scribbled notes on.">
  <div class="recipe-page">

    <header class="page-header">
      <h1>Recipe Box</h1>
      <p class="page-intro">
        Recipes I've actually made, with honest notes about what I changed
        and whether I'd make them again. No aesthetic food photography — just real opinions.
      </p>
    </header>

    <div class="recipe-feed">
      {sorted.map((recipe) => (
        <article class="recipe-entry card">
          <div class="recipe-header">
            <div class="recipe-heading">
              <h2>
                <a href={`/recipes/${contentSlugFromId(recipe.id)}`}>{recipe.data.title}</a>
              </h2>
              <div class="recipe-meta">
                {recipe.data.source && (
                  <span class="source">
                    {recipe.data.sourceUrl ? (
                      <a href={recipe.data.sourceUrl} target="_blank" rel="noopener noreferrer">{recipe.data.source}</a>
                    ) : (
                      recipe.data.source
                    )}
                  </span>
                )}
              </div>
            </div>

            <div class="recipe-badges">
              {recipe.data.rating && (
                <span class="rating" aria-label={starsLabel(recipe.data.rating)}>
                  {starsHtml(recipe.data.rating)}
                </span>
              )}
              {recipe.data.wouldMakeAgain ? (
                <span class="tag">would make again</span>
              ) : (
                <span class="tag terracotta">once was enough</span>
              )}
            </div>
          </div>

          {recipe.data.tags.length > 0 && (
            <div class="tag-row">
              {recipe.data.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          )}

          <p class="recipe-link">
            <a href={`/recipes/${contentSlugFromId(recipe.id)}`}>read the full notes &rarr;</a>
          </p>
        </article>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .recipe-page {
    padding: var(--space-4) 0;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }
  .page-header h1 { color: var(--color-sage-dark); margin-bottom: var(--space-3); }
  .page-intro {
    max-width: 520px;
    margin: 0 auto;
    color: var(--color-ink-soft);
    font-style: italic;
  }

  .recipe-feed {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .recipe-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .recipe-header h2 {
    color: var(--color-ink);
    margin-bottom: var(--space-1);
  }

  .recipe-header h2 a {
    color: inherit;
    text-decoration: none;
  }

  .recipe-header h2 a:hover {
    color: var(--color-terracotta);
  }

  .recipe-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .source {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }

  .recipe-badges {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-2);
  }

  .rating {
    color: var(--color-gold);
    letter-spacing: 0.15em;
    font-size: var(--text-sm);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .recipe-link {
    margin: var(--space-4) 0 0;
    max-width: none;
  }

  .recipe-link a {
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }
</style>
