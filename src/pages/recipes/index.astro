---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { starsHtml, starsLabel } from '../../utils/stars';
import { contentSlugFromId } from '../../utils/contentSlug';

const allRecipes = await getCollection('recipes');
const sorted = allRecipes.sort((a, b) => {
  const da = a.data.dateTried?.getTime() ?? 0;
  const db = b.data.dateTried?.getTime() ?? 0;
  return db - da;
});
const makeAgainCount = sorted.filter((recipe) => recipe.data.wouldMakeAgain).length;
const ratedRecipes = sorted.filter((recipe) => typeof recipe.data.rating === 'number');
const averageRating = ratedRecipes.length > 0
  ? (ratedRecipes.reduce((sum, recipe) => sum + (recipe.data.rating ?? 0), 0) / ratedRecipes.length).toFixed(1)
  : null;
---

<BaseLayout title="Recipe Box" description="Recipes Marihella has tried, loved, and scribbled notes on.">
  <div class="recipe-page">

    <header class="page-header">
      <h1>Recipe Box</h1>
      <p class="page-intro">
        Recipes I've actually made, with honest notes about what I changed
        and whether I'd make them again. No aesthetic food photography — just real opinions.
      </p>
    </header>

    <section class="kitchen-notes" aria-label="Kitchen notes">
      <article class="kitchen-note card">
        <p class="kitchen-note-label">Tried so far</p>
        <p class="kitchen-note-value">{sorted.length}</p>
        <p class="kitchen-note-copy">recipes that made it out of the tab pile and into the actual kitchen</p>
      </article>
      <article class="kitchen-note card">
        <p class="kitchen-note-label">Would make again</p>
        <p class="kitchen-note-value">{makeAgainCount}</p>
        <p class="kitchen-note-copy">keepers worth scribbling into the permanent recipe notebook</p>
      </article>
      <article class="kitchen-note card">
        <p class="kitchen-note-label">Average delight</p>
        <p class="kitchen-note-value">{averageRating ? `${averageRating}/5` : 'pending'}</p>
        <p class="kitchen-note-copy">an unscientific measurement of how likely I am to make a second batch</p>
      </article>
    </section>

    <div class="recipe-feed">
      {sorted.map((recipe) => (
        <article class="recipe-entry card">
          <div class="recipe-header">
            <div class="recipe-heading">
              <h2>
                <a href={`/recipes/${contentSlugFromId(recipe.id)}`}>{recipe.data.title}</a>
              </h2>
              <div class="recipe-meta">
                {recipe.data.source && (
                  <span class="source">
                    {recipe.data.sourceUrl ? (
                      <a href={recipe.data.sourceUrl} target="_blank" rel="noopener noreferrer">{recipe.data.source}</a>
                    ) : (
                      recipe.data.source
                    )}
                  </span>
                )}
              </div>
            </div>

            <div class="recipe-badges">
              {recipe.data.rating && (
                <span class="rating" aria-label={starsLabel(recipe.data.rating)}>
                  {starsHtml(recipe.data.rating)}
                </span>
              )}
              {recipe.data.wouldMakeAgain ? (
                <span class="tag">would make again</span>
              ) : (
                <span class="tag terracotta">once was enough</span>
              )}
            </div>
          </div>

          {recipe.data.tags.length > 0 && (
            <div class="tag-row">
              {recipe.data.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          )}

          <p class="recipe-link">
            <a href={`/recipes/${contentSlugFromId(recipe.id)}`}>read the full notes &rarr;</a>
          </p>
        </article>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .recipe-page {
    padding: var(--space-4) 0;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }
  .page-header h1 { color: var(--color-sage-dark); margin-bottom: var(--space-3); }
  .page-intro {
    max-width: 520px;
    margin: 0 auto;
    color: var(--color-ink-soft);
    font-style: italic;
  }

  .kitchen-notes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-10, 2.5rem);
  }

  .kitchen-note {
    position: relative;
    overflow: hidden;
  }

  .kitchen-note::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, rgba(212, 133, 58, 0.12), transparent 58%);
    pointer-events: none;
  }

  .kitchen-note-label,
  .kitchen-note-value,
  .kitchen-note-copy {
    position: relative;
    z-index: 1;
    max-width: none;
  }

  .kitchen-note-label {
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 var(--space-2);
  }

  .kitchen-note-value {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-style: italic;
    color: var(--color-sage-dark);
    margin: 0 0 var(--space-2);
  }

  .kitchen-note-copy {
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
    margin: 0;
  }

  .recipe-feed {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .recipe-entry {
    position: relative;
    overflow: hidden;
  }

  .recipe-entry::before {
    content: '';
    position: absolute;
    inset: 10px;
    border: 1px dashed rgba(200, 152, 78, 0.15);
    border-radius: calc(var(--radius-md) - 4px);
    pointer-events: none;
  }

  .recipe-entry::after {
    content: 'kitchen note';
    position: absolute;
    top: var(--space-3);
    right: var(--space-4);
    font-family: var(--font-accent);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(200, 152, 78, 0.45);
    pointer-events: none;
  }

  .recipe-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .recipe-header h2 {
    color: var(--color-ink);
    margin-bottom: var(--space-1);
  }

  .recipe-header h2 a {
    color: inherit;
    text-decoration: none;
  }

  .recipe-header h2 a:hover {
    color: var(--color-terracotta);
  }

  .recipe-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .source {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }

  .recipe-badges {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-2);
  }

  .rating {
    color: var(--color-gold);
    letter-spacing: 0.15em;
    font-size: var(--text-sm);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .recipe-link {
    margin: var(--space-4) 0 0;
    max-width: none;
  }

  .recipe-link a {
    font-family: var(--font-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  @media (max-width: 720px) {
    .kitchen-notes {
      grid-template-columns: 1fr;
    }
  }
</style>
